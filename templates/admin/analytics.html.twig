{#
  Analytics module, rendered inside the shared Anokii shell. Instance-specific
  data (App\Analytics\AnalyticsReport) presented with the shell's chrome and
  rhtcircle theme. Context: report (totals/pages/referrers/devices), range, plus
  the AdminShell context.
#}
{% extends "anokii/admin/_base.html.twig" %}

{% block admin_styles %}
  .rng{ display:flex; align-items:flex-end; gap:12px; flex-wrap:wrap; margin:0 0 8px; }
  .rng .field{ display:flex; flex-direction:column; gap:6px; }
  .rng label{ font-size:11px; font-weight:600; letter-spacing:.1em; text-transform:uppercase; color:var(--anokii-shell-muted); }
  .rng input[type=date]{ font-family:var(--anokii-mono,monospace); font-size:14px; color:var(--anokii-shell-ink); background:var(--anokii-shell-card); border:1px solid var(--anokii-shell-line); border-radius:8px; padding:8px 10px; }
  .rng input[type=date]:focus{ outline:none; border-color:var(--anokii-shell-accent); }
  .rng button{ font-size:12px; font-weight:600; letter-spacing:.06em; text-transform:uppercase; color:var(--anokii-shell-accent-ink); background:var(--anokii-shell-accent); border:none; border-radius:999px; padding:10px 22px; cursor:pointer; }
  .big{ grid-template-columns:repeat(auto-fill,minmax(180px,1fr)); }
  .big .anokii-stat span{ font-size:clamp(30px,6vw,46px); line-height:1; }
  .panels{ display:grid; grid-template-columns:1fr 1fr; gap:16px; }
  @media(max-width:640px){ .panels{ grid-template-columns:1fr; } }
  .bar{ padding:9px 0; border-bottom:1px solid var(--anokii-shell-line); }
  .bar:last-child{ border-bottom:none; }
  .bar .h{ display:flex; justify-content:space-between; gap:14px; margin-bottom:7px; }
  .bar .n{ font-size:14px; color:var(--anokii-shell-muted); text-transform:capitalize; }
  .bar .c{ font-family:var(--anokii-mono,monospace); font-size:13px; color:var(--anokii-shell-ink); }
  .track{ height:6px; background:var(--anokii-shell-line); border-radius:3px; overflow:hidden; }
  .fill{ display:block; height:100%; background:var(--anokii-shell-accent); border-radius:3px; }
  .li{ display:flex; justify-content:space-between; gap:14px; padding:9px 0; border-bottom:1px solid var(--anokii-shell-line); }
  .li:last-child{ border-bottom:none; }
  .li .n{ font-size:14px; color:var(--anokii-shell-muted); word-break:break-all; }
  .li .c{ font-family:var(--anokii-mono,monospace); font-size:13px; color:var(--anokii-shell-ink); }
  .muted-i{ color:var(--anokii-shell-muted); font-style:italic; font-size:14px; }
{% endblock %}

{% block admin_content %}
  <section class="anokii-hero">
    <h1>Analytics</h1>
    <div class="mean">{{ range.from }} to {{ range.to }}</div>
    <p>First-party, cookie-less analytics. No personal data stored; visitors are counted by a daily-rotating salted hash. No third party, no ad-tech.</p>
  </section>

  <form method="get" class="rng">
    <div class="field"><label for="from">From</label><input type="date" id="from" name="from" value="{{ range.from }}"></div>
    <div class="field"><label for="to">To</label><input type="date" id="to" name="to" value="{{ range.to }}"></div>
    <button type="submit">Apply</button>
  </form>

  <h2 class="anokii-h2">Totals</h2>
  <div class="anokii-stats big">
    <div class="anokii-stat"><b>Pageviews</b><span>{{ report.totals.views }}</span></div>
    <div class="anokii-stat"><b>Visitors</b><span>{{ report.totals.visitors }}</span></div>
  </div>

  <h2 class="anokii-h2">Pages</h2>
  <div class="anokii-scroll anokii-card" style="padding:8px 14px">
    <table class="anokii-table">
      <thead><tr><th>Path</th><th>Views</th><th>Visitors</th></tr></thead>
      <tbody>
        {% for row in report.pages %}
          <tr><td class="mono">{{ row.path }}</td><td>{{ row.views }}</td><td>{{ row.visitors }}</td></tr>
        {% else %}
          <tr><td class="empty" colspan="3">No data for this range yet.</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  <h2 class="anokii-h2">Referrers and devices</h2>
  <div class="panels">
    <div class="anokii-card">
      <b style="font-size:12px;letter-spacing:.06em;text-transform:uppercase;color:var(--anokii-shell-accent)">Top referrers</b>
      {% if report.referrers is empty %}
        <p class="muted-i" style="margin-top:12px">Direct / none recorded</p>
      {% else %}
        <div style="margin-top:10px">
          {% for ref in report.referrers %}<div class="li"><span class="n">{{ ref.host }}</span><span class="c">{{ ref.count }}</span></div>{% endfor %}
        </div>
      {% endif %}
    </div>
    <div class="anokii-card">
      <b style="font-size:12px;letter-spacing:.06em;text-transform:uppercase;color:var(--anokii-shell-accent)">Devices</b>
      {% if report.devices is empty %}
        <p class="muted-i" style="margin-top:12px">None recorded</p>
      {% else %}
        {% set device_max = 0 %}
        {% for d in report.devices %}{% if d.count > device_max %}{% set device_max = d.count %}{% endif %}{% endfor %}
        <div style="margin-top:10px">
          {% for d in report.devices %}
            <div class="bar">
              <div class="h"><span class="n">{{ d.device }}</span><span class="c">{{ d.count }}</span></div>
              <div class="track"><span class="fill" style="width: {{ device_max > 0 ? (d.count / device_max * 100)|round(1) : 0 }}%"></span></div>
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
{% endblock %}
