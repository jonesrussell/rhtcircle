<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}Robinson Huron Treaty · A member resource for the treaty and its 21 nations{% endblock %}</title>
  <meta name="description" content="{% block description %}A member-led resource for the Robinson Huron Treaty and its 21 First Nations: what the 1850 treaty is, the communities of the territory, what is happening on the land, and the member-led transparency work on the shared settlement.{% endblock %}">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Robinson Huron Treaty resource (rhtcircle.ca)">
  <meta property="og:title" content="{% block og_title %}{{ block('title') }}{% endblock %}">
  <meta property="og:description" content="{% block og_description %}{{ block('description') }}{% endblock %}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/site.css">
  {# First-party, self-hosted analytics. Same-origin beacon to /api/collect, no
     third party, no cookies, respects Do Not Track. #}
  <script defer src="/js/rht-analytics.js"></script>
  {# Public Co-Intelligence launcher (the nav backbone). Streams from our own
     /api/chat; the model key stays server-side. Injects its own UI into body. #}
  <script defer src="/js/rht-anokii-chat.js"></script>
  {% block head_styles %}{% endblock %}
  {% block head_extra %}{% endblock %}
</head>
<body class="{% block body_class %}{% endblock %}">
<a class="skip" href="#main">Skip to content</a>

<hr class="rainbow-rule">
<header class="site-head">
  <div class="wrap wrap--wide">
    <p class="site-title"><a href="/">Robinson Huron Treaty</a></p>
    <p class="site-tag">A member resource for the treaty and its 21 nations.</p>
    <nav class="site-nav" aria-label="Primary">
      <a href="/treaty" {% if nav == 'treaty' %}aria-current="page"{% endif %}>The Treaty</a>
      <a href="/communities" {% if nav == 'communities' %}aria-current="page"{% endif %}>Communities</a>
      <a href="/land" {% if nav == 'land' %}aria-current="page"{% endif %}>The Land</a>
      <a href="/safety" {% if nav == 'safety' %}aria-current="page"{% endif %}>Community Safety</a>
      <a href="/resources" {% if nav == 'resources' %}aria-current="page"{% endif %}>Resources</a>
      <a href="/standard" {% if nav == 'transparency' %}aria-current="page"{% endif %}>Transparency</a>
      <a href="/circle" {% if nav == 'circle' %}aria-current="page"{% endif %}>The Circle</a>
      <a href="/about" {% if nav == 'about' %}aria-current="page"{% endif %}>About</a>
    </nav>
  </div>
</header>

{% block hero %}{% endblock %}

<main id="main">
  <div class="{% block main_class %}wrap{% endblock %}">
    {% block content %}{% endblock %}
  </div>
</main>

<footer class="site-foot">
  <div class="wrap wrap--wide">
    <nav class="foot-links" aria-label="Footer">
      <a href="/treaty">The Treaty</a>
      <a href="/communities">Communities</a>
      <a href="/land">The Land</a>
      <a href="/safety">Community Safety</a>
      <a href="/resources">Resources</a>
      <a href="/standard">Transparency</a>
      <a href="/circle">The Circle</a>
      <a href="/about">About</a>
    </nav>
    <p class="disclaimer"><strong>Independent and member-led.</strong> This is an independent, member-led resource for the Robinson Huron Treaty and its 21 First Nations. It is not the Robinson Huron Treaty Litigation Fund and is not affiliated with it. The member-led Transparency Circle within it is non-partisan: it works from sourced facts framed as questions, and it does not make accusations.</p>
    <p class="muted">Prepared by members, for members.</p>
  </div>
</footer>

{% block scripts %}{% endblock %}
</body>
</html>
