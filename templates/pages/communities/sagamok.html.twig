{% extends 'base.html.twig' %}
{% set nav = 'communities' %}

{% block title %}Sagamok Anishnawbek · Communities · Robinson Huron Treaty{% endblock %}
{% block description %}A member-compiled, unofficial profile of Sagamok Anishnawbek, and the hub for the member transparency work that touches the community: the shared standard, the records request, how Sagamok is organized, and the Massey solar project.{% endblock %}
{% block og_description %}A member-compiled, unofficial profile of Sagamok Anishnawbek, with links to the transparency work and land decisions that touch the community.{% endblock %}

{% block hero %}
<section class="hero">
  <div class="wrap wrap--wide">
    <p class="eyebrow">Communities · {{ nation.region_name }}</p>
    <h1>{{ nation.name }}.</h1>
    <p class="lead">A member-compiled profile of Sagamok, and the hub for the parts of this resource that touch the community: the shared transparency standard applied here, the records request, how the Nation is organized, and the land decisions on Sagamok territory.</p>
    <p class="nation-chips">
      {% include 'components/region_chip.html.twig' with { region: nation.sub_region } only %}
    </p>
  </div>
</section>
{% endblock %}

{% block content %}
  {% include 'partials/nation_banner.html.twig' %}

  {% include 'components/section_heading.html.twig' with { title: 'Profile' } only %}
  {% include 'partials/nation_facts.html.twig' %}

  {% include 'components/section_heading.html.twig' with { title: 'History and treaty relationship' } only %}
  {{ nation.history|raw }}

  {% if nation.note %}
    {% set note_body %}<strong>A note on the figures.</strong> {{ nation.note }}{% endset %}
    {% include 'components/notice.html.twig' with { body: note_body } only %}
  {% endif %}

  {% include 'partials/nation_official.html.twig' %}

  {% include 'components/section_heading.html.twig' with { title: 'Member transparency resources for Sagamok', note: 'Sagamok is where the shared standard became a worked example. The community-level questions any member can put to their own Chief and Council live in the shared standard. The pages below are Sagamok members putting that standard into practice. They are the work of members, not of Chief and Council.' } only %}
  <ul class="community-grid">
    <li><a class="community-card" href="/standard/records-request">
      <p class="name">The records request</p>
      <p class="status is-live">The standard, in practice</p>
    </a></li>
    <li><a class="community-card" href="/communities/sagamok/how-its-organized">
      <p class="name">How Sagamok is organized</p>
      <p class="status is-live">A member's guide</p>
    </a></li>
    <li><a class="community-card" href="/communities/sagamok/members-website-issue">
      <p class="name">The members website issue</p>
      <p class="status is-live">Reported and resolved</p>
    </a></li>
  </ul>

  {% include 'components/section_heading.html.twig' with { title: 'On Sagamok territory', note: 'Decisions about the land and its resources reach members here too. They live in the land section, which covers resource and energy decisions and member wellbeing across the treaty, not under any one community.' } only %}
  <ul class="community-grid">
    <li><a class="community-card" href="/land/massey-solar-project">
      <p class="name">The Massey solar project</p>
      <p class="status is-live">On Sagamok territory</p>
    </a></li>
    <li><a class="community-card" href="/land/north-shore-link-northeast-power-line">
      <p class="name">North Shore Link and Northeast Power Line</p>
      <p class="status is-live">Sagamok is a Waasmoowin partner</p>
    </a></li>
    <li><a class="community-card" href="/safety">
      <p class="name">Community safety</p>
      <p class="status is-live">Help, MMIWG, and safety in the territory</p>
    </a></li>
  </ul>

  <div class="btn-row">
    <a class="btn" href="/standard">The full shared standard</a>
    <a class="btn btn--alt" href="/circle">Be a local contact</a>
  </div>

  {% include 'components/section_heading.html.twig' with { title: 'Sources' } only %}
  {% include 'partials/nation_sources.html.twig' %}

  {% include 'components/freshness.html.twig' with { datetime: last_updated('nations') } only %}
{% endblock %}
