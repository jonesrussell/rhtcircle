{% extends 'base.html.twig' %}
{% set nav = 'communities' %}

{% block title %}Sagamok Anishnawbek · Communities · Robinson Huron Treaty{% endblock %}
{% block description %}A member-compiled, unofficial profile of Sagamok Anishnawbek, and the hub for the member transparency work that touches the community: the shared standard, the records request, how Sagamok is organized, and the Massey solar project.{% endblock %}
{% block og_description %}A member-compiled, unofficial profile of Sagamok Anishnawbek, with links to the transparency work and land decisions that touch the community.{% endblock %}

{% block hero %}
<section class="hero">
  <div class="wrap wrap--wide">
    <p class="eyebrow">Communities · {{ nation.region_name }}</p>
    <h1>{{ nation.name }}.</h1>
    <p class="lead">A member-compiled profile of Sagamok, and the hub for the parts of this resource that touch the community: the shared transparency standard applied here, the records request, how the Nation is organized, and the land decisions on Sagamok territory.</p>
  </div>
</section>
{% endblock %}

{% block content %}
  {% include 'partials/nation_banner.html.twig' %}

  <h2>Profile</h2>
  {% include 'partials/nation_facts.html.twig' %}

  <h2>History and treaty relationship</h2>
  {{ nation.history|raw }}

  {% if nation.note %}
  <div class="card">
    <p class="muted"><strong>A note on the figures.</strong> {{ nation.note }}</p>
  </div>
  {% endif %}

  {% include 'partials/nation_official.html.twig' %}

  <h2>Member transparency resources for Sagamok</h2>
  <p>Sagamok is where the shared standard became a worked example. The community-level questions any member can put to their own Chief and Council live in <a href="/standard">the shared standard</a>. The pages below are Sagamok members putting that standard into practice. They are independent of the Sagamok Chief and Council and of the Litigation Fund.</p>
  <ul class="community-grid">
    <li><a class="community-card" href="/standard/records-request">
      <p class="name">The records request</p>
      <p class="status is-live">The standard, in practice</p>
    </a></li>
    <li><a class="community-card" href="/communities/sagamok/how-its-organized">
      <p class="name">How Sagamok is organized</p>
      <p class="status is-live">A member's guide</p>
    </a></li>
    <li><a class="community-card" href="/communities/sagamok/members-website-issue">
      <p class="name">The members website issue</p>
      <p class="status is-live">Reported and resolved</p>
    </a></li>
  </ul>

  <h2>On Sagamok territory</h2>
  <p>Decisions about the land and its resources reach members here too. They live in <a href="/land">the land section</a>, which covers resource and energy decisions and member wellbeing across the treaty, not under any one community.</p>
  <ul class="community-grid">
    <li><a class="community-card" href="/land/massey-solar-project">
      <p class="name">The Massey solar project</p>
      <p class="status is-live">On Sagamok territory</p>
    </a></li>
    <li><a class="community-card" href="/land/territory-and-safety">
      <p class="name">Territory and member safety</p>
      <p class="status is-live">A neutral, sourced note</p>
    </a></li>
  </ul>

  <div class="btn-row">
    <a class="btn" href="/standard">The full shared standard</a>
    <a class="btn btn--alt" href="/circle">Be a local contact</a>
  </div>

  <h2>Sources</h2>
  {% include 'partials/nation_sources.html.twig' %}
{% endblock %}
