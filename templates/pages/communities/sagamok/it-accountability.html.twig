    --border:var(--rule); --warn:var(--accent-deep);
  }
  main .wrap { padding-top: 40px; padding-bottom: 64px; }
  .ita .hlw{background:var(--accent-wash); color:var(--ink); padding:.03em .28em; border-radius:4px; font-weight:600; box-decoration-break:clone; -webkit-box-decoration-break:clone}
  .ita .summary{background:var(--panel); border:1px solid var(--border); border-radius:14px; padding:8px 22px 12px; margin:26px 0 8px}
  .ita .summary p.h{font-size:12.5px; letter-spacing:.14em; text-transform:uppercase; color:var(--muted); font-weight:600; margin:16px 0 10px}
  .ita ul{margin:0 0 18px; padding-left:0; list-style:none}
  .ita li{position:relative; padding-left:22px; margin:0 0 11px}
  .ita li::before{content:""; position:absolute; left:3px; top:12px; width:6px; height:6px; border-radius:50%; background:var(--accent)}
  .ita ol.asks{margin:0 0 18px; padding-left:22px}
  .ita ol.asks li{padding-left:6px; margin:0 0 14px; line-height:1.6}
  .ita .pull{font-size:21px; line-height:1.4; color:var(--ink); font-weight:600; border-left:3px solid var(--accent); padding:4px 0 4px 20px; margin:22px 0}
  .ita .timeline{position:relative; margin:16px 0 18px; padding-left:36px}
  .ita .timeline::before{content:""; position:absolute; left:9px; top:8px; bottom:12px; width:2px; background:linear-gradient(180deg,var(--accent),var(--border))}
  .ita .tl{position:relative; padding:0 0 24px}
  .ita .tl:last-child{padding-bottom:0}
