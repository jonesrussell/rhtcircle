  {% include 'components/section_heading.html.twig' with { title: 'The committee seats' } only %}
  <p>Councillors' own biography pages list these additional committee and working-group seats:</p>

  <div class="osos-table-wrap">
    <table class="osos-table is-roster">
      <colgroup><col style="width:26%"><col style="width:74%"></colgroup>
      <thead>
