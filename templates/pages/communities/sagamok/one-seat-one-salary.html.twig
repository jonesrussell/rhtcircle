          <td class="nm">Arnelda Bennett</td>
          <td>Councillor</td>
          <td>Economic Development Manager</td>
          <td class="src"><a href="https://www.sagamokanishnawbek.com/directory" target="_blank" rel="noopener">staff directory</a></td>
        </tr>
