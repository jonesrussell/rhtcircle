{% extends 'base.html.twig' %}
{% set nav = 'communities' %}

{% block title %}Paid at every table · Robinson Huron Treaty{% endblock %}
{% block description %}A member-compiled record: the thirteen people elected to Sagamok's Chief and Council hold at least fifty-five paid roles between them, in staff jobs, company boards, and committees. Every figure is sourced to Sagamok's own public record, with a simple ask.{% endblock %}
{% block og_description %}Thirteen people elected to Sagamok's Chief and Council hold at least fifty-five paid roles between them. What the public record shows, and a simple ask.{% endblock %}
{% block body_class %}route-sagamok-one-seat-one-salary{% endblock %}

{% block head_styles %}
<style>
  /* Scoped .osos-* table + callout, matching the records-request rrl-matrix
     pattern (site design tokens, not page-local hex values). */
  .osos-table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; margin: var(--gap-4) 0 var(--gap-2); border: 1px solid var(--rule); border-radius: var(--radius-lg); background: var(--paper-2); }
  .osos-table { border-collapse: collapse; width: 100%; min-width: 640px; font-family: var(--font-sans); font-size: 14px; }
  .osos-table th, .osos-table td { border-bottom: 1px solid var(--rule); padding: 10px 14px; text-align: left; vertical-align: top; }
  .osos-table thead th { color: var(--ink-3); font-size: 11px; text-transform: uppercase; letter-spacing: 0.04em; font-weight: 700; }
  .osos-table tbody tr:last-child td { border-bottom: none; }
  .osos-table td.nm { color: var(--ink); font-weight: 600; white-space: nowrap; }
  .osos-table td.src { white-space: nowrap; }
  .osos-note { font-family: var(--font-sans); font-size: 12.5px; color: var(--ink-3); line-height: 1.5; margin: 0 0 var(--gap-5); max-width: 90ch; }

  /* Roster tables (company boards, committees): cells hold long name lists,
     not short dot-grid marks, so give them explicit proportioned columns
     instead of leaving auto-layout to squeeze the widest column. */
  .osos-table.is-roster { table-layout: fixed; min-width: 720px; }
  .osos-table.is-roster td.nm { white-space: normal; }

  .osos-quote { font-family: var(--font-serif); font-size: 20px; line-height: 1.5; color: var(--ink); border-left: 3px solid var(--accent); padding: 4px 0 4px 20px; margin: var(--gap-4) 0; }
  .osos-quote cite { display: block; font-family: var(--font-sans); font-size: 13px; font-style: normal; color: var(--ink-3); margin-top: 8px; }

  .osos-ask { margin: var(--gap-5) 0; background: var(--accent-wash); border: 1px solid var(--accent-soft); border-left: 4px solid var(--accent); border-radius: var(--radius-md); padding: 18px 22px; }
  .osos-ask p { margin: 0; max-width: none; }

  /* The count: a running tally, styled as a receipt-like strip rather than a
     table (the point is the arithmetic, not a data grid). */
  .osos-count { border: 1px solid var(--rule); border-radius: var(--radius-lg); background: var(--paper-2); padding: 6px 22px; margin: var(--gap-4) 0 var(--gap-2); }
  .osos-count-row { display: flex; align-items: baseline; gap: 12px; padding: 12px 0; border-bottom: 1px solid var(--rule); font-family: var(--font-sans); }
  .osos-count-row:last-of-type { border-bottom: none; }
  .osos-count-row .op { font-family: var(--font-serif); font-size: 20px; color: var(--ink-3); width: 1.2em; flex: none; }
  .osos-count-row .fig { font-family: var(--font-serif); font-size: 20px; font-weight: 600; color: var(--ink); width: 2.2em; flex: none; }
  .osos-count-row .lab { color: var(--ink-2); line-height: 1.5; }
  .osos-count-total { display: flex; align-items: baseline; gap: 12px; padding: 14px 0 16px; font-family: var(--font-sans); }
  .osos-count-total .op { font-family: var(--font-serif); font-size: 20px; color: var(--accent-deep); width: 1.2em; flex: none; }
  .osos-count-total .fig { font-family: var(--font-serif); font-size: 26px; font-weight: 700; color: var(--accent-deep); width: 2.2em; flex: none; }
  .osos-count-total .lab { color: var(--ink); font-weight: 600; line-height: 1.4; }
</style>
{% endblock %}

{% block content %}
  <p class="crumb"><a href="/communities">Communities</a> › <a href="/communities/sagamok">Sagamok Anishnawbek</a> › Paid at every table</p>

  <p class="eyebrow">Sagamok Anishnawbek · A member's ask</p>
  <h1>Paid at every table</h1>
  <p class="lead">The thirteen people elected to Sagamok's Chief and Council, the Chief and twelve Councillors, do not each hold one paid role. Between them, they hold at least fifty-five. Every figure below is from Sagamok's own public record.</p>

  {% set banner_body %}<strong>Member-compiled and unofficial.</strong> This is a member-compiled summary, not an official communication of Sagamok Anishnawbek. <a href="/about#corrections">Tell us what we got wrong</a> and we will correct it.{% endset %}
  {% include 'components/notice.html.twig' with { variant: 'caveat', body: banner_body, label: 'About this page' } only %}

  {% include 'components/section_heading.html.twig' with { title: 'The count' } only %}
  <div class="osos-count">
    <div class="osos-count-row"><span class="op">&nbsp;</span><span class="fig">13</span><span class="lab">elected seats: the Chief and twelve Councillors</span></div>
    <div class="osos-count-row"><span class="op">+</span><span class="fig">7</span><span class="lab">paid staff jobs: seven of the twelve Councillors are also on the Nation's payroll</span></div>
    <div class="osos-count-row"><span class="op">+</span><span class="fig">28</span><span class="lab">seats on the boards of the Nation's companies, per the corporate registry</span></div>
    <div class="osos-count-row"><span class="op">+</span><span class="fig">7</span><span class="lab">committee seats that Councillors list on their own biography pages</span></div>
    <div class="osos-count-total"><span class="op">=</span><span class="fig">55</span><span class="lab">at least fifty-five paid roles, held by 13 people</span></div>
  </div>
  <p class="osos-note">This counts only the committees Councillors chose to list on their own biography pages. The full committee roster is not published, so the real number is higher. Members have asked Council to release it.</p>

  {% include 'components/section_heading.html.twig' with { title: 'The staff jobs' } only %}
