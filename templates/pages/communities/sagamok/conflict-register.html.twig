    var boards = DATA.boards;
    var decisions = DATA.decisions;

    function fmtMoney(n) {
      try { return '$' + Number(n).toLocaleString('en-CA', { maximumFractionDigits: 2 }); } catch (e) { return '$' + n; }
    }

    function esc(s) {
      var d = document.createElement('div'); d.textContent = s == null ? '' : String(s); return d.innerHTML;
    }

    // Resolves the full director roster for an entity string, which is
    // sometimes compound ("ZCLP / OCL", "ZEI / ZCLP / OCL / Legend Mining")
    // when one motion names more than one company. Matches each named part
    // against the boards keys (exact, or a prefix match either direction,
    // since some minute entries abbreviate a company name) and merges.
    function dget(entity) {
      var out = {};
      (entity || '').split('/').forEach(function (part) {
        var p = part.trim();
        Object.keys(boards).forEach(function (k) {
          if (p === k || p.indexOf(k) === 0 || k.indexOf(p) === 0) {
            Object.keys(boards[k]).forEach(function (n) { out[n] = boards[k][n]; });
          }
        });
      });
      return out;
    }

    // Person roster: every named councillor-director across all boards,
    // with a count of decisions about companies they direct.
    var people = {};
    decisions.forEach(function (d) {
      Object.keys(dget(d.entity)).forEach(function (n) {
        people[n] = (people[n] || 0) + 1;
      });
    });

    var companySel = document.querySelector('[data-cr-company]');
    var termSel = document.querySelector('[data-cr-term]');
    var sortSel = document.querySelector('[data-cr-sort]');
    var resetBtn = document.querySelector('[data-cr-reset]');
    var statsEl = document.querySelector('[data-cr-stats]');
    var peopleEl = document.querySelector('[data-cr-people]');
    var countEl = document.querySelector('[data-cr-count]');
    var rowsEl = document.querySelector('[data-cr-rows]');
    if (!companySel || !termSel || !sortSel || !rowsEl || !peopleEl) return;

    var allCompanies = [];
    decisions.forEach(function (d) { if (allCompanies.indexOf(d.entity) === -1) allCompanies.push(d.entity); });
    allCompanies.sort().forEach(function (n) {
      var o = document.createElement('option'); o.value = n; o.textContent = n; companySel.appendChild(o);
    });

    var selPerson = '';
    Object.keys(people).sort(function (a, b) { return people[b] - people[a]; }).forEach(function (n) {
      var btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'cr-person';
      btn.dataset.name = n;
      btn.innerHTML = esc(n) + ' <small>(' + people[n] + ')</small>';
      btn.addEventListener('click', function () {
        selPerson = (selPerson === n) ? '' : n;
        render();
      });
      peopleEl.appendChild(btn);
    });

    function render() {
      var list = decisions.slice();
      if (selPerson) list = list.filter(function (d) { return Object.prototype.hasOwnProperty.call(dget(d.entity), selPerson); });
      if (companySel.value) list = list.filter(function (d) { return d.entity === companySel.value; });
      if (termSel.value) list = list.filter(function (d) { return d.term === termSel.value; });

      var s = sortSel.value;
      list.sort(function (a, b) {
        if (s === 'amt_desc') return (b.amount || 0) - (a.amount || 0);
        if (s === 'date_asc') return a.date.localeCompare(b.date);
        return b.date.localeCompare(a.date);
      });

      peopleEl.querySelectorAll('.cr-person').forEach(function (btn) {
        btn.classList.toggle('is-active', btn.dataset.name === selPerson);
      });

      var moneyRows = list.filter(function (d) { return d.amount; });
      var total = moneyRows.reduce(function (sum, d) { return sum + d.amount; }, 0);
      var abstentionCount = list.filter(function (d) { return d.abstention; }).length;

      if (statsEl) {
        statsEl.innerHTML =
          '<div class="cr-stat"><span class="cr-stat__n">' + list.length + '</span><span class="cr-stat__l">decisions shown</span></div>' +
          '<div class="cr-stat"><span class="cr-stat__n">' + esc(fmtMoney(total)) + '</span><span class="cr-stat__l">money to these companies (shown)</span></div>' +
          '<div class="cr-stat"><span class="cr-stat__n">' + abstentionCount + '</span><span class="cr-stat__l">abstentions recorded</span></div>';
      }

      if (countEl) {
        countEl.textContent = selPerson
          ? 'Showing decisions about companies ' + selPerson + ' directs.'
          : 'Showing ' + list.length + ' decisions. Pick a councillor or a company to narrow.';
      }

      rowsEl.innerHTML = list.map(function (d) {
        var dirs = dget(d.entity);
        var dirNames = Object.keys(dirs);
        var chips = dirNames.length
          ? dirNames.map(function (n) {
              var role = dirs[n];
              var hl = (n === d.mover || n === d.seconder || n === selPerson);
              return '<span class="cr-chip' + (hl ? ' is-voter' : '') + '">' + esc(n) + ' · ' + esc(role) + '</span>';
            }).join('')
          : '<span class="cr-td-none">not councillor-directed</span>';

        var amountCell = d.amount
          ? '<td class="cr-td-amount">' + esc(fmtMoney(d.amount)) + '</td>'
          : '<td class="cr-td-amount is-none">not a cash amount</td>';

        var text = d.text.length > 150 ? d.text.slice(0, 150) + '…' : d.text;

        var recusalCell = d.abstention
          ? '<span class="cr-badge cr-badge--abstention">Abstention: ' + esc(d.abstention) + '</span>'
          : '<span class="cr-badge">No recusal recorded</span>';

        var dateTags = (d.term === 'prior' ? '<span class="cr-tag--prior">prior term</span>' : '') +
          (d.incamera ? '<span class="cr-tag--incamera">in-camera</span>' : '');

        return '<tr>' +
          '<td class="cr-td-date">' + esc(d.date) + dateTags + '</td>' +
          '<td class="cr-td-entity">' + esc(d.entity) + '</td>' +
          '<td>' + esc(text) + '</td>' +
          amountCell +
          '<td>' + esc(d.mover) + ' / ' + esc(d.seconder) + '</td>' +
          '<td><div class="cr-chips">' + chips + '</div></td>' +
          '<td>' + recusalCell + '</td>' +
          '</tr>';
      }).join('');
    }

    companySel.addEventListener('change', render);
    termSel.addEventListener('change', render);
    sortSel.addEventListener('change', render);
    if (resetBtn) {
      resetBtn.addEventListener('click', function () {
        selPerson = '';
        companySel.value = '';
        termSel.value = '';
        sortSel.value = 'date_desc';
        render();
      });
    }

    document.querySelectorAll('.cr-table thead th.is-sortable').forEach(function (th) {
      th.addEventListener('click', function () {
        var key = th.dataset.sortKey;
        sortSel.value = key === 'amt' ? 'amt_desc' : (sortSel.value === 'date_desc' ? 'date_asc' : 'date_desc');
        render();
      });
    });

    render();
  })();
</script>
{% endblock %}
