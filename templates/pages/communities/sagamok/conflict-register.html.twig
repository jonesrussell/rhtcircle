{% extends 'base.html.twig' %}
{% set nav = 'communities' %}

{% block title %}The Conflict Register · Robinson Huron Treaty{% endblock %}
{% block description %}A member-built tool: pick a Sagamok councillor to see, in plain words, the enterprise money decisions where Council handled business for a company they help run, and whether anyone stepped out of the vote.{% endblock %}
{% block og_description %}Pick a Sagamok councillor and see their conflicts in plain words: which company they direct, what the decision did, and whether a recusal was recorded.{% endblock %}
{% block body_class %}route-sagamok-conflict-register{% endblock %}
{% block main_class %}wrap wrap--wide{% endblock %}

{% block head_styles %}
<style>
  /* Scoped .cr-* people row, filter bar, stat strip, and card grid, built
     from site design tokens, not page-local hex values. Tool-first layout:
     intro, stats, people picker, filters, cards, all above the fold on a
     laptop; the disclaimer and sources sit at the bottom, small and muted. */
  .cr-stats { display: flex; flex-wrap: wrap; gap: 14px; margin: 0 0 var(--gap-5); }
  .cr-stat { flex: 1 1 180px; border-radius: var(--radius-lg); border: 1px solid var(--rule); background: var(--paper-2); padding: 14px 18px; }
  .cr-stat__n { display: block; font-family: var(--font-serif); font-size: 26px; font-weight: 700; color: var(--accent-deep); font-variant-numeric: tabular-nums; line-height: 1.15; }
  .cr-stat__l { display: block; margin-top: 4px; font-family: var(--font-sans); font-size: 13px; color: var(--ink-2); }

  .cr-people { display: flex; flex-wrap: wrap; gap: 8px; margin: 0 0 var(--gap-4); }
  .cr-person { font: inherit; font-family: var(--font-sans); font-size: 14px; font-weight: 600; color: var(--ink); background: #fff; border: 1px solid var(--rule-strong); border-radius: 999px; padding: 8px 16px; cursor: pointer; }
  .cr-person small { color: var(--ink-3); font-weight: 400; margin-left: 3px; }
  .cr-person.is-zero { color: var(--ink-3); opacity: 0.7; }
  .cr-person.is-active { background: var(--accent); border-color: var(--accent); color: #fff; }
  .cr-person.is-active small { color: rgba(255, 255, 255, 0.85); }
  .cr-person:hover { border-color: var(--accent-soft); }
  .cr-person:focus-visible { outline: 3px solid var(--accent); outline-offset: 2px; }

  .cr-ctx { display: none; background: var(--paper-2); border-radius: var(--radius-md); padding: 14px 18px; margin: 0 0 var(--gap-4); font-family: var(--font-sans); font-size: 14.5px; line-height: 1.55; color: var(--ink-2); }
  .cr-ctx strong { color: var(--ink); }
  .cr-seat { display: inline-block; background: #fff; border: 1px solid var(--rule-strong); color: var(--ink-2); border-radius: 999px; padding: 2px 10px; font-size: 12.5px; font-weight: 600; margin: 2px 4px 2px 0; }

  .cr-filter { display: flex; flex-wrap: wrap; gap: 10px; margin: 0 0 var(--gap-3); }
  .cr-filter__select { font: inherit; font-size: 14px; color: var(--ink); background: #fff; border: 1px solid var(--rule-strong); border-radius: 8px; padding: 9px 11px; }
  .cr-filter__reset { font: inherit; font-weight: 700; font-size: 14px; color: var(--ink); background: var(--paper-2); border: 1px solid var(--rule-strong); border-radius: 8px; padding: 9px 14px; cursor: pointer; }
  .cr-filter__reset:hover { border-color: var(--accent-soft); }
  .cr-filter__select:focus-visible, .cr-filter__reset:focus-visible { outline: 3px solid var(--accent); outline-offset: 2px; }

  .cr-count { font-family: var(--font-sans); font-size: 13px; color: var(--ink-3); margin: 0 0 var(--gap-4); min-height: 1.4em; }

  .cr-cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(330px, 1fr)); gap: 14px; margin: 0 0 var(--gap-6); }
  .cr-card { border: 1px solid var(--rule); border-left: 5px solid var(--coral); border-radius: var(--radius-lg); background: var(--paper-2); padding: 16px 18px; }
  .cr-card.is-ok { border-left-color: var(--blue); }
  .cr-card__head { display: flex; justify-content: space-between; align-items: baseline; gap: 10px; }
  .cr-card__co { font-family: var(--font-serif); font-size: 17px; font-weight: 700; color: var(--ink); }
  .cr-card__amt { font-family: var(--font-sans); font-size: 17px; font-weight: 700; color: var(--accent-deep); white-space: nowrap; }
  .cr-card__amt.is-none { color: var(--ink-3); font-size: 13px; font-weight: 600; }
  .cr-card__meta { font-family: var(--font-sans); font-size: 12.5px; color: var(--ink-3); margin: 4px 0 10px; }
  .cr-tag--prior, .cr-tag--incamera { display: inline-block; background: var(--paper); border: 1px solid var(--rule); color: var(--ink-3); border-radius: 4px; padding: 1px 6px; font-size: 10.5px; margin-left: 6px; white-space: nowrap; }
  .cr-card__why { font-family: var(--font-sans); font-size: 14px; line-height: 1.55; color: var(--ink-2); margin: 0 0 8px; }
  .cr-card__why strong { color: var(--ink); }
  .cr-card__dirlabel { font-family: var(--font-sans); font-size: 14px; margin: 0 0 6px; }
  .cr-card__dirlabel strong { color: var(--ink); }
  .cr-chips { display: flex; flex-wrap: wrap; gap: 4px; margin: 0 0 8px; }
  .cr-chip { display: inline-block; background: #fff; border: 1px solid var(--rule-strong); color: var(--ink-2); border-radius: 999px; padding: 2px 10px; font-family: var(--font-sans); font-size: 12px; font-weight: 600; white-space: nowrap; }
  .cr-chip.is-voter { background: var(--accent-wash); border-color: var(--accent-soft); color: var(--accent-deep); }
  .cr-card__rec { margin-top: 6px; font-family: var(--font-sans); font-size: 13px; font-weight: 700; color: var(--coral); }
  .cr-card__rec.is-ok { color: var(--blue); }

  .cr-disclaimer { background: var(--paper-2); border-radius: var(--radius-md); padding: 14px 18px; margin: var(--gap-5) 0 0; font-family: var(--font-sans); font-size: 12.5px; line-height: 1.6; color: var(--ink-3); }
  .cr-disclaimer strong { color: var(--ink-2); }

  @media (max-width: 560px) {
    .cr-cards { grid-template-columns: 1fr; }
    .cr-filter__select, .cr-filter__reset { flex: 1 1 46%; }
  }
</style>
{% endblock %}

{% block content %}
  <p class="crumb"><a href="/communities">Communities</a> › <a href="/communities/sagamok">Sagamok Anishnawbek</a> › The Conflict Register</p>

  <p class="eyebrow">Sagamok Anishnawbek · A member's accountability tool</p>
  <h1>The Conflict Register</h1>
  <p class="lead">Councillors sit on the boards of the Nation's companies. Pick a councillor to see the decisions where Council handled money or business for a company they help run, and whether they stepped out of the vote.</p>

  <div class="cr-stats" data-cr-stats></div>

  {% include 'components/section_heading.html.twig' with { title: 'Pick a councillor' } only %}
  <div class="cr-people" data-cr-people></div>
  <div class="cr-ctx" data-cr-ctx></div>

  <form class="cr-filter" aria-label="Filter the conflict register" data-cr-filter onsubmit="return false">
    <select class="cr-filter__select" id="cr-company" data-cr-company aria-label="Filter by company">
      <option value="">All companies</option>
    </select>
    <select class="cr-filter__select" id="cr-term" data-cr-term aria-label="Filter by term">
      <option value="">Both terms</option>
      <option value="current">Current term</option>
      <option value="prior">Prior term</option>
    </select>
    <select class="cr-filter__select" id="cr-sort" data-cr-sort aria-label="Sort">
      <option value="date_desc">Newest first</option>
      <option value="date_asc">Oldest first</option>
      <option value="amt_desc">Biggest amount</option>
    </select>
    <button class="cr-filter__reset" type="button" data-cr-reset>Reset</button>
  </form>

  <p class="cr-count" data-cr-count></p>

  <div class="cr-cards" data-cr-cards></div>

  <div class="cr-disclaimer">
    <strong>How to read this.</strong> Every figure is from the Nation's own Council minutes and the corporate registry. "No recusal recorded" means the minutes do not show a councillor stepping out over a board seat, a question for Council, not a finding of wrongdoing. The minutes do record six abstentions across both terms, and nearly all are a councillor stepping out over her own <em>employment</em> (for example "as Economic Development Manager"), not over a company she directs. In-camera and prior-term rows (before the August 2024 election) are marked; board membership may have differed on earlier dates.
  </div>

  {% include 'components/section_heading.html.twig' with { title: 'Right of reply' } only %}
  <p>Chief and Council have been asked to confirm this information and submit corrections. Any correction will be reflected here.</p>

  {% include 'components/section_heading.html.twig' with { title: 'Sources' } only %}
  <ul class="src-links">
    <li>The Nation's Council minutes, cited by motion number and date</li>
    <li><a href="https://www.ontario.ca/page/ontario-business-registry" target="_blank" rel="noopener">Ontario Business Registry</a> and Corporations Canada's <a href="https://ised-isde.canada.ca/cc/lgcy/fdrlCrpDtls.html?corpId=11017624" target="_blank" rel="noopener">federal corporate registry</a> (board and officer roles)</li>
    <li><a href="https://zgamok.ca/our-team" target="_blank" rel="noopener">zgamok.ca, our team</a> (board and officer roles)</li>
    <li>Financial Administration Law, sections 21 and 22 (conflict declaration and recusal) and section 11 (Finance and Audit Committee independence)</li>
  </ul>

  <p class="cover__byline">A community resource from the Robinson Huron Treaty hub, member-led and independent. Facts are from public sources; the questions are for our leadership. Corrections welcome.</p>
{% endblock %}

