{% extends 'base.html.twig' %}
{% set nav = 'communities' %}

{% block title %}The Conflict Register · Robinson Huron Treaty{% endblock %}
{% block description %}A member-built tool: pick a Sagamok councillor to see every company they direct and every enterprise money decision about those companies, across both Council terms, who moved and seconded each, and whether an abstention was recorded.{% endblock %}
{% block og_description %}Pick a Sagamok councillor or company and see the enterprise money decisions: who moved and seconded them, who on Council directs the recipient, and whether an abstention was recorded.{% endblock %}
{% block body_class %}route-sagamok-conflict-register{% endblock %}
{% block main_class %}wrap wrap--wide{% endblock %}

{% block head_styles %}
<style>
  /* Scoped .cr-* people row, filter bar, stat pills, and table, built from
     site design tokens, not page-local hex values. */
  .cr-stats { display: flex; flex-wrap: wrap; gap: 14px; margin: 0 0 var(--gap-5); }
  .cr-stat { flex: 1 1 200px; border-radius: var(--radius-lg); border: 1px solid var(--rule); background: var(--paper-2); padding: 14px 18px; }
  .cr-stat__n { display: block; font-family: var(--font-serif); font-size: 28px; font-weight: 700; color: var(--accent-deep); font-variant-numeric: tabular-nums; line-height: 1.15; }
  .cr-stat__l { display: block; margin-top: 4px; font-family: var(--font-sans); font-size: 13px; color: var(--ink-2); }

  .cr-people { display: flex; flex-wrap: wrap; gap: 8px; margin: 0 0 var(--gap-5); }
  .cr-person { font: inherit; font-family: var(--font-sans); font-size: 14px; font-weight: 600; color: var(--ink); background: #fff; border: 1px solid var(--rule-strong); border-radius: 999px; padding: 8px 16px; cursor: pointer; }
  .cr-person small { color: var(--ink-3); font-weight: 400; margin-left: 3px; }
  .cr-person.is-active { background: var(--accent); border-color: var(--accent); color: #fff; }
  .cr-person.is-active small { color: rgba(255, 255, 255, 0.85); }
  .cr-person:hover { border-color: var(--accent-soft); }
  .cr-person:focus-visible { outline: 3px solid var(--accent); outline-offset: 2px; }

  .cr-filter { display: flex; flex-wrap: wrap; align-items: flex-end; gap: 14px; margin: 0 0 var(--gap-4); }
  .cr-filter__group { display: flex; flex-direction: column; gap: 4px; }
  .cr-filter__label { font-family: var(--font-sans); font-size: 12px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-2); }
  .cr-filter__select { font: inherit; color: var(--ink); background: #fff; border: 1px solid var(--rule-strong); border-radius: 8px; padding: 9px 12px; min-width: 200px; }
  .cr-filter__reset { font: inherit; font-weight: 700; color: #fff; background: var(--accent); border: 0; border-radius: 999px; padding: 10px 20px; cursor: pointer; align-self: flex-end; }
  .cr-filter__reset:hover { background: var(--accent-deep); }
  .cr-filter__select:focus-visible, .cr-filter__reset:focus-visible { outline: 3px solid var(--accent); outline-offset: 2px; }

  .cr-count { font-family: var(--font-sans); font-size: 14px; color: var(--ink-2); margin: 0 0 var(--gap-3); min-height: 1.4em; }

  .cr-table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; border: 1px solid var(--rule); border-radius: var(--radius-lg); background: var(--paper-2); margin: 0 0 var(--gap-5); }
  .cr-table { border-collapse: collapse; width: 100%; min-width: 1000px; font-family: var(--font-sans); font-size: 13.5px; }
  .cr-table th, .cr-table td { border-bottom: 1px solid var(--rule); padding: 10px 12px; text-align: left; vertical-align: top; }
  .cr-table thead th { color: var(--ink-3); font-size: 11px; text-transform: uppercase; letter-spacing: 0.04em; font-weight: 700; white-space: nowrap; }
  .cr-table thead th.is-sortable { cursor: pointer; }
  .cr-table thead th.is-sortable:hover { color: var(--accent-deep); }
  .cr-table tbody tr:last-child td { border-bottom: none; }
  .cr-td-date { white-space: nowrap; }
  .cr-td-entity { font-weight: 700; color: var(--ink); white-space: nowrap; }
  .cr-td-amount { font-weight: 700; color: var(--accent-deep); white-space: nowrap; text-align: right; }
  .cr-td-amount.is-none { color: var(--ink-3); font-weight: 400; font-style: italic; text-align: left; white-space: normal; }
  .cr-tag--prior { display: inline-block; background: var(--paper); border: 1px solid var(--rule); color: var(--ink-3); border-radius: 4px; padding: 1px 6px; font-size: 10.5px; margin-left: 6px; white-space: nowrap; }
  .cr-tag--incamera { display: inline-block; background: var(--paper); border: 1px solid var(--rule); color: var(--ink-3); border-radius: 4px; padding: 1px 6px; font-size: 10.5px; margin-left: 6px; white-space: nowrap; }
  .cr-chips { display: flex; flex-wrap: wrap; gap: 4px; }
  .cr-chip { display: inline-block; background: #fff; border: 1px solid var(--rule-strong); color: var(--ink-2); border-radius: 999px; padding: 2px 10px; font-family: var(--font-sans); font-size: 12px; font-weight: 600; white-space: nowrap; }
  .cr-chip.is-voter { background: var(--accent-wash); border-color: var(--accent-soft); color: var(--accent-deep); }
  .cr-td-none { color: var(--ink-3); }
  .cr-badge { display: inline-block; background: var(--paper); border: 1px solid var(--coral); color: var(--coral); border-radius: 999px; padding: 3px 10px; font-family: var(--font-sans); font-size: 12px; font-weight: 700; white-space: normal; }
  .cr-badge--abstention { border-color: var(--blue); color: var(--blue); }

  @media (max-width: 560px) {
    .cr-filter__select { min-width: 100%; }
    .cr-filter__group { width: 100%; }
    .cr-filter__reset { width: 100%; }
  }
</style>
{% endblock %}

{% block content %}
  <p class="crumb"><a href="/communities">Communities</a> › <a href="/communities/sagamok">Sagamok Anishnawbek</a> › The Conflict Register</p>

  <p class="eyebrow">Sagamok Anishnawbek · A member's accountability tool</p>
  <h1>The Conflict Register</h1>
  <p class="lead">Councillors sit on the boards of the Nation's companies. When Council votes to send those companies the Nation's money, a councillor with a personal interest is supposed to declare it and step out of the vote (Financial Administration Law, sections 21 and 22). Pick a councillor to see every company they direct and every decision about those companies, or filter by company.</p>

  {% set banner_body %}Every figure is from the Nation's own Council minutes and the public corporate registry. The minutes record six abstentions across both terms, and nearly all of them are a councillor stepping out of a vote over her own employment, for example "as Economic Development Manager," not over a company she directs. "No recusal recorded" means the minutes do not show any councillor stepping out over their board or officer seat, a question for Council to answer, not a finding of wrongdoing. In-camera decisions and prior-term rows (before the August 2024 election) are marked; board membership may have differed on those earlier dates.{% endset %}
  {% include 'components/notice.html.twig' with { variant: 'caveat', body: banner_body, label: 'How to read this' } only %}

  <div class="cr-stats" data-cr-stats></div>

  {% include 'components/section_heading.html.twig' with { title: 'Pick a councillor' } only %}
  <div class="cr-people" data-cr-people></div>

  <form class="cr-filter" aria-label="Filter the conflict register" data-cr-filter onsubmit="return false">
    <div class="cr-filter__group">
      <label class="cr-filter__label" for="cr-company">Company</label>
      <select class="cr-filter__select" id="cr-company" data-cr-company>
        <option value="">All companies</option>
      </select>
    </div>
    <div class="cr-filter__group">
      <label class="cr-filter__label" for="cr-term">Term</label>
      <select class="cr-filter__select" id="cr-term" data-cr-term>
        <option value="">Both terms</option>
        <option value="current">Current term</option>
        <option value="prior">Prior term</option>
      </select>
    </div>
    <div class="cr-filter__group">
      <label class="cr-filter__label" for="cr-sort">Sort</label>
      <select class="cr-filter__select" id="cr-sort" data-cr-sort>
        <option value="date_desc">Newest first</option>
        <option value="date_asc">Oldest first</option>
        <option value="amt_desc">Amount high to low</option>
      </select>
    </div>
    <button class="cr-filter__reset" type="button" data-cr-reset>Reset</button>
  </form>

  <p class="cr-count" data-cr-count></p>

  <div class="cr-table-wrap">
    <table class="cr-table">
      <thead>
        <tr>
          <th class="is-sortable" data-sort-key="date">Date</th>
          <th>Company</th>
          <th>Decision</th>
          <th class="is-sortable" data-sort-key="amt">Amount</th>
          <th>Moved / seconded</th>
          <th>Councillor-directors</th>
          <th>Recusal</th>
        </tr>
      </thead>
      <tbody data-cr-rows></tbody>
    </table>
  </div>

  {% include 'components/section_heading.html.twig' with { title: 'Right of reply' } only %}
  <p>Chief and Council have been asked to confirm this information and submit corrections. Any correction will be reflected here.</p>

  {% include 'components/section_heading.html.twig' with { title: 'Sources' } only %}
  <ul class="src-links">
    <li>The Nation's Council minutes, cited by motion number and date</li>
    <li><a href="https://www.ontario.ca/page/ontario-business-registry" target="_blank" rel="noopener">Ontario Business Registry</a> and Corporations Canada's <a href="https://ised-isde.canada.ca/cc/lgcy/fdrlCrpDtls.html?corpId=11017624" target="_blank" rel="noopener">federal corporate registry</a> (board and officer roles)</li>
    <li><a href="https://zgamok.ca/our-team" target="_blank" rel="noopener">zgamok.ca, our team</a> (board and officer roles)</li>
    <li>Financial Administration Law, sections 21 and 22 (conflict declaration and recusal) and section 11 (Finance and Audit Committee independence)</li>
  </ul>
  <p class="osos-note">Member-built research; it states sourced facts and asks questions, and alleges no wrongdoing by any individual. Board seats change; figures are as recorded. Release the conflict declarations and recusal records, and members can see the safeguard was followed.</p>

  <p class="cover__byline">A community resource from the Robinson Huron Treaty hub, member-led and independent. Facts are from public sources; the questions are for our leadership. Corrections welcome.</p>
{% endblock %}

