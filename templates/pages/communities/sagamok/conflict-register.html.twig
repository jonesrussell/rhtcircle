    var boards = DATA.boards;
    var decisions = DATA.decisions;

    function money(n) {
      try { return '$' + Number(n).toLocaleString('en-CA'); } catch (e) { return '$' + n; }
    }

    function esc(s) {
      var d = document.createElement('div'); d.textContent = s == null ? '' : String(s); return d.innerHTML;
    }

    function dget(entity) {
      var out = {};
      (entity || '').split('/').forEach(function (part) {
        var p = part.trim();
        Object.keys(boards).forEach(function (k) {
          if (p === k || p.indexOf(k) === 0 || k.indexOf(p) === 0) {
            Object.keys(boards[k]).forEach(function (n) { out[n] = boards[k][n]; });
          }
        });
      });
      return out;
    }

    function seatsOf(name) {
      var out = {};
      Object.keys(boards).forEach(function (e) {
        if (Object.prototype.hasOwnProperty.call(boards[e], name)) out[e] = boards[e][name];
      });
      return out;
    }

    function decCount(name) {
      return decisions.filter(function (d) { return Object.prototype.hasOwnProperty.call(dget(d.entity), name); }).length;
    }

    var companySel = document.querySelector('[data-cr-company]');
    var termSel = document.querySelector('[data-cr-term]');
    var sortSel = document.querySelector('[data-cr-sort]');
    var resetBtn = document.querySelector('[data-cr-reset]');
    var statsEl = document.querySelector('[data-cr-stats]');
    var peopleEl = document.querySelector('[data-cr-people]');
    var ctxEl = document.querySelector('[data-cr-ctx]');
    var countEl = document.querySelector('[data-cr-count]');
    var cardsEl = document.querySelector('[data-cr-cards]');
    if (!companySel || !termSel || !sortSel || !cardsEl || !peopleEl) return;

    var allCompanies = [];
    decisions.forEach(function (d) { if (allCompanies.indexOf(d.entity) === -1) allCompanies.push(d.entity); });
    allCompanies.sort().forEach(function (n) {
      var o = document.createElement('option'); o.value = n; o.textContent = n; companySel.appendChild(o);
    });

    var sel = '';
    DATA.councillors.map(function (n) { return [n, decCount(n)]; })
      .sort(function (a, b) { return b[1] - a[1]; })
      .forEach(function (pair) {
        var n = pair[0], c = pair[1];
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'cr-person' + (c === 0 ? ' is-zero' : '');
        btn.dataset.name = n;
        btn.innerHTML = esc(n) + ' <small>(' + c + ')</small>';
        btn.addEventListener('click', function () {
          sel = (sel === n) ? '' : n;
          render();
        });
        peopleEl.appendChild(btn);
      });

    function involvement(d, name) {
      if (d.mover === name) return 'moved this vote';
      if (d.seconder === name) return 'seconded this vote';
      return 'sat on the Council that passed it';
    }

    function coNameOf(entity) { return entity.split('/')[0].trim(); }

    function whatDid(d) {
      var co = coNameOf(d.entity);
      return d.amount ? ('sent ' + co + ' ' + money(d.amount)) : ('was a decision about ' + co);
    }

    function render() {
      var list = decisions.slice();
      if (sel) list = list.filter(function (d) { return Object.prototype.hasOwnProperty.call(dget(d.entity), sel); });
      if (companySel.value) list = list.filter(function (d) { return d.entity === companySel.value; });
      if (termSel.value) list = list.filter(function (d) { return d.term === termSel.value; });

      var s = sortSel.value;
      list.sort(function (a, b) {
        if (s === 'amt_desc') return (b.amount || 0) - (a.amount || 0);
        if (s === 'date_asc') return a.date.localeCompare(b.date);
        return b.date.localeCompare(a.date);
      });

      peopleEl.querySelectorAll('.cr-person').forEach(function (btn) {
        btn.classList.toggle('is-active', btn.dataset.name === sel);
      });

      var total = list.filter(function (d) { return d.amount; }).reduce(function (sum, d) { return sum + d.amount; }, 0);
      var abstentionCount = list.filter(function (d) { return d.abstention; }).length;

      if (statsEl) {
        statsEl.innerHTML =
          '<div class="cr-stat"><span class="cr-stat__n">' + list.length + '</span><span class="cr-stat__l">decisions shown</span></div>' +
          '<div class="cr-stat"><span class="cr-stat__n">' + esc(money(total)) + '</span><span class="cr-stat__l">money to these companies</span></div>' +
          '<div class="cr-stat"><span class="cr-stat__n">' + abstentionCount + '</span><span class="cr-stat__l">abstentions recorded</span></div>';
      }

      if (ctxEl) {
        if (sel) {
          var seats = seatsOf(sel);
          var seatNames = Object.keys(seats);
          ctxEl.style.display = 'block';
          if (seatNames.length) {
            var chips = seatNames.map(function (e) { return '<span class="cr-seat">' + esc(e) + ' · ' + esc(seats[e]) + '</span>'; }).join('');
            ctxEl.innerHTML = '<strong>' + esc(sel) + '</strong> holds seats on the Nation\'s companies: ' + chips + '<br>Below: every decision where Council handled money or business for one of those companies.';
          } else {
            ctxEl.innerHTML = '<strong>' + esc(sel) + '</strong> holds no seat on any of the Nation\'s companies. No conflict decisions to show, and that is the point of showing it.';
          }
        } else {
          ctxEl.style.display = 'none';
        }
      }

      if (countEl) {
        countEl.textContent = sel
          ? (list.length + ' decisions involving companies ' + sel + ' helps run')
          : (list.length + ' decisions. Pick a councillor to see their conflicts in plain words.');
      }

      cardsEl.innerHTML = list.map(function (d) {
        var dirs = dget(d.entity);
        var co = coNameOf(d.entity);
        var ab = d.abstention;

        var why;
        if (sel) {
          var role = dirs[sel] || 'a director';
          why = '<p class="cr-card__why"><strong>' + esc(sel) + '</strong> is ' + esc(role) + ' of ' + esc(co) + '. This decision ' + esc(whatDid(d)) + ', and ' + esc(sel) + ' ' + esc(involvement(d, sel)) + '.</p>';
        } else {
          var dirNames = Object.keys(dirs);
          var chips = dirNames.map(function (n) {
            var hl = (n === d.mover || n === d.seconder);
            return '<span class="cr-chip' + (hl ? ' is-voter' : '') + '">' + esc(n) + ' · ' + esc(dirs[n]) + '</span>';
          }).join('');
          why = '<p class="cr-card__dirlabel"><strong>Councillors who help run ' + esc(co) + ':</strong></p>' +
            '<div class="cr-chips">' + chips + '</div>' +
            '<p class="cr-card__why">This decision ' + esc(whatDid(d)) + '. The people who govern ' + esc(co) + ' are the same people who voted on it.</p>';
        }

        var rec = ab
          ? '<p class="cr-card__rec is-ok">Abstention recorded: ' + esc(ab) + '</p>'
          : '<p class="cr-card__rec">No recusal recorded, no one stepped out of this vote.</p>';

        var amtHtml = d.amount
          ? '<span class="cr-card__amt">' + esc(money(d.amount)) + '</span>'
          : '<span class="cr-card__amt is-none">no cash amount</span>';

        var tags = (d.term === 'prior' ? '<span class="cr-tag--prior">prior term</span>' : '') +
          (d.incamera ? '<span class="cr-tag--incamera">in-camera</span>' : '');

        return '<article class="cr-card' + (ab ? ' is-ok' : '') + '">' +
          '<div class="cr-card__head"><span class="cr-card__co">' + esc(co) + '</span>' + amtHtml + '</div>' +
          '<p class="cr-card__meta">' + esc(d.date) + ' · ' + esc(d.motion) + tags + '</p>' +
          why + rec +
          '</article>';
      }).join('');
    }

    companySel.addEventListener('change', render);
    termSel.addEventListener('change', render);
    sortSel.addEventListener('change', render);
    if (resetBtn) {
      resetBtn.addEventListener('click', function () {
        sel = '';
        companySel.value = '';
        termSel.value = '';
        sortSel.value = 'date_desc';
        render();
      });
    }

    render();
  })();
</script>
{% endblock %}
