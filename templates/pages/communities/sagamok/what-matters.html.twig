{% extends 'base.html.twig' %}
{% set nav = 'communities' %}
{% block main_class %}{% endblock %}

{#
  Anonymous, single-select member poll for Sagamok. See src/Poll for the
  storage model: a vote is an aggregate counter, never a per-voter row, so
  there is nothing here that identifies who voted or how. Results only ever
  render after this browser has voted (has_voted, set from a stateless
  per-poll cookie, never from a database lookup keyed to a person).
#}

{% block title %}Sagamok members: what matters most right now? · Robinson Huron Treaty{% endblock %}
{% block description %}An anonymous, informal member poll for Sagamok Anishnawbek: what should our leadership be focused on right now? Single select, no personal data collected, results shown after voting.{% endblock %}
{% block og_title %}Sagamok members: what matters most right now?{% endblock %}
{% block og_description %}An anonymous, informal member poll. Pick the one thing you want Sagamok's leadership focused on right now.{% endblock %}
{% block body_class %}route-sagamok-what-matters{% endblock %}

{% block head_styles %}
  <style>
    .wm-wrap { max-width: 680px; margin: 0 auto; padding: var(--gap-7) var(--gap-5) var(--gap-9); }
    .wm-wrap .eyebrow { font-size: 12.5px; letter-spacing: .16em; text-transform: uppercase; color: var(--ink-3); margin: 0 0 16px; font-weight: 600; }
    .wm-wrap h1 { font-family: var(--serif); font-size: clamp(26px, 4.2vw, 36px); line-height: 1.2; letter-spacing: -0.01em; font-weight: 600; color: var(--indigo-deep); margin: 0 0 var(--gap-3); }
    .wm-lede { font-size: 17px; line-height: 1.55; color: var(--ink-2); margin: 0 0 var(--gap-4); max-width: 62ch; }

    .wm-form { display: flex; flex-direction: column; gap: var(--gap-5); margin: var(--gap-5) 0; }
    .wm-options { display: flex; flex-direction: column; gap: 10px; }
    .wm-opt { display: flex; align-items: flex-start; gap: 12px; border: 1px solid var(--rule); border-radius: 10px; padding: 13px 16px; cursor: pointer; background: #fff; }
    .wm-opt:hover { border-color: var(--indigo); }
    .wm-opt input[type="radio"] { margin-top: 3px; accent-color: var(--indigo); flex: none; }
    .wm-opt span { font-size: 15.5px; line-height: 1.45; color: var(--ink); }
    .wm-opt input[type="radio"]:focus-visible { outline: 3px solid var(--magenta); outline-offset: 2px; }

    .wm-send { font: inherit; font-weight: 700; color: #fff; background: var(--indigo); border: 0; border-radius: 999px; padding: 13px 28px; cursor: pointer; align-self: flex-start; }
    .wm-send:hover { background: var(--indigo-deep); }
    .wm-send[disabled] { opacity: .6; cursor: default; }

    .wm-hp { position: absolute; left: -9999px; width: 1px; height: 1px; overflow: hidden; }

    .wm-status { margin: 0 0 var(--gap-4); border-radius: 10px; padding: 0; }
    .wm-status[data-state="error"] { padding: 12px 14px; background: #fdeaf3; border: 1px solid var(--magenta); color: var(--magenta-deep, #98146d); font-weight: 600; font-size: 14.5px; }

    .wm-results h2 { font-family: var(--serif); font-size: 20px; color: var(--indigo-deep); margin: 0 0 4px; font-weight: 600; }
    .wm-results .wm-total { font-size: 14px; color: var(--ink-3); margin: 0 0 var(--gap-4); }
    .wm-rows { display: flex; flex-direction: column; gap: 14px; margin: 0 0 var(--gap-5); }
    .wm-row-label { display: flex; justify-content: space-between; gap: 12px; font-size: 15px; color: var(--ink); margin: 0 0 6px; }
    .wm-row-label strong { font-weight: 600; }
    .wm-row-label .wm-pct { font-family: var(--sans); font-weight: 700; color: var(--indigo-deep); white-space: nowrap; }
    .wm-bar { background: var(--paper-2); border: 1px solid var(--rule); border-radius: 999px; height: 12px; overflow: hidden; }
    .wm-bar-fill { height: 100%; background: var(--indigo); border-radius: 999px 0 0 999px; }
    .wm-row.is-picked .wm-row-label strong::after { content: " (your pick)"; font-weight: 400; color: var(--ink-3); }
    .wm-row.is-picked .wm-bar-fill { background: var(--magenta); }
  </style>
{% endblock %}

{% block content %}
<div class="wm-wrap">
  <p class="eyebrow">Sagamok &middot; An informal member poll</p>
  <h1>{{ question }}</h1>
  <p class="wm-lede">Members are asking each other this directly. Pick the one thing you want our leadership focused on right now. It is single select, anonymous, and results are shown right after you vote.</p>

  <p class="notice">An informal member poll. Indicative, not an official vote.</p>

  {% if has_voted and results %}
    <div class="wm-results">
      <h2>Miigwech, here is what members are saying so far</h2>
      <p class="wm-total">{{ results.total }} vote{{ results.total == 1 ? '' : 's' }} so far</p>
      <div class="wm-rows">
        {% for o in results.options %}
          <div class="wm-row{{ o.id == voted_option_id ? ' is-picked' : '' }}">
            <p class="wm-row-label"><strong>{{ o.label }}</strong><span class="wm-pct">{{ o.percent }}%</span></p>
            <div class="wm-bar"><div class="wm-bar-fill" style="width: {{ o.percent }}%"></div></div>
          </div>
        {% endfor %}
      </div>
    </div>

    <div class="cta">
      <div class="cta__body">
        <p class="cta__h">See the records request</p>
        <p class="cta__line">The related, formal ask: sixteen member questions about the settlement, the trust, the enterprises, and the benefit to members, carried with signatures.</p>
      </div>
      <a class="cta__btn" href="/standard/records-request">Read the records request</a>
    </div>
  {% else %}
    <div class="wm-status" data-poll-status role="status" aria-live="polite"></div>

    <form class="wm-form" data-poll-form novalidate>
      <div class="wm-hp" aria-hidden="true">
        <label>Leave this blank<input type="text" name="website" tabindex="-1" autocomplete="off"></label>
      </div>

      <div class="wm-options" role="radiogroup" aria-label="{{ question }}">
        {% for o in options %}
          <label class="wm-opt">
            <input type="radio" name="option_id" value="{{ o.id }}" required>
            <span>{{ o.label }}</span>
          </label>
        {% endfor %}
      </div>

      <button class="wm-send" type="submit" data-poll-send>Cast your vote</button>
    </form>
  {% endif %}
</div>

<script>
  (function () {
    var form = document.querySelector('[data-poll-form]');
    if (!form) return;
    var statusBox = document.querySelector('[data-poll-status]');
    var sendBtn = document.querySelector('[data-poll-send]');

    function show(state, text) {
      statusBox.setAttribute('data-state', state);
      statusBox.textContent = text;
    }

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      show('', '');

      var picked = form.querySelector('input[name="option_id"]:checked');
      if (!picked) { show('error', 'Please choose one option.'); return; }

      sendBtn.disabled = true;
      var label = sendBtn.textContent;
      sendBtn.textContent = 'Sending...';

      fetch('/api/poll/vote', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({
          slug: 'sagamok-what-matters',
          option_id: parseInt(picked.value, 10),
          website: form.website.value
        })
      }).then(function (r) {
        return r.json().catch(function () { return { ok: false }; });
      }).then(function (data) {
        if (data && data.ok) {
          window.location.reload();
        } else {
          sendBtn.disabled = false;
          sendBtn.textContent = label;
          show('error', (data && data.error) ? data.error : 'Something went wrong. Please try again.');
        }
      }).catch(function () {
        sendBtn.disabled = false;
        sendBtn.textContent = label;
        show('error', 'Could not reach the server. Please check your connection and try again.');
      });
    });
  })();
</script>
{% endblock %}
