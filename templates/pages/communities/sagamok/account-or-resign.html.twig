{% extends 'base.html.twig' %}
{% set nav = 'communities' %}

{% block title %}Sagamok Members' Accountability Resolution · Robinson Huron Treaty{% endblock %}
{% block description %}The seven-part Sagamok Members' Accountability Resolution submitted to Chief and Council on July 24, 2026. Read it and continue adding your support.{% endblock %}
{% block og_description %}Submitted to Sagamok Chief and Council on July 24. Read the seven requested actions and continue adding your signature.{% endblock %}
{% block body_class %}route-sagamok-member-accountability-resolution{% endblock %}
{% block main_class %}wrap wrap--wide{% endblock %}

{% block head_styles %}
<style>
  .mar-prose { max-width: 820px; margin: 0 auto; }
  .mar-banner { margin: 0; background: linear-gradient(120deg, var(--indigo-deep), var(--indigo)); }
  .mar-banner img { display: block; width: 100%; height: auto; }
  .mar-grid { display: grid; grid-template-columns: minmax(0, 1.6fr) minmax(260px, .8fr); gap: var(--gap-6); align-items: start; margin: var(--gap-6) 0; }
  .mar-card { background: var(--paper-2); border: 1px solid var(--rule); border-radius: var(--radius-lg); padding: 22px; }
  .mar-card h2, .mar-card h3 { margin-top: 0; }
  .mar-status { display: inline-flex; align-items: center; gap: 8px; border-radius: 999px; background: var(--accent-wash); color: var(--accent-deep); padding: 6px 12px; font: 700 12px/1 var(--font-sans); text-transform: uppercase; letter-spacing: .05em; }
  .mar-status::before { content: ''; width: 8px; height: 8px; border-radius: 50%; background: var(--accent); }
  .mar-dates { list-style: none; margin: 16px 0 0; padding: 0; }
  .mar-dates li { display: grid; grid-template-columns: 110px 1fr; gap: 12px; padding: 9px 0; border-top: 1px solid var(--rule); }
  .mar-dates time { font-weight: 700; color: var(--ink); }
  .mar-disclaimer { border-left: 4px solid var(--blue); background: color-mix(in srgb, var(--blue) 8%, var(--paper)); padding: 18px 20px; border-radius: 0 var(--radius-md) var(--radius-md) 0; margin: var(--gap-5) 0; }
  .mar-disclaimer p { margin: 0; }
  .mar-update { border: 1px solid var(--accent-soft); border-left: 6px solid var(--accent); background: var(--accent-wash); border-radius: var(--radius-md); padding: 19px 21px; margin: var(--gap-5) 0; }
  .mar-update strong { color: var(--accent-deep); }
  .mar-update p { margin: 4px 0; }
  .mar-resolution { background: var(--paper); border: 1px solid var(--rule-strong); border-radius: var(--radius-lg); padding: clamp(22px, 4vw, 38px); margin: var(--gap-6) 0; }
  .mar-resolution header { border-bottom: 2px solid var(--ink); padding-bottom: 18px; margin-bottom: 24px; }
  .mar-resolution header p { margin: 4px 0 0; color: var(--ink-3); }
  .mar-resolution > p { line-height: 1.7; }
  .mar-resolved { font-family: var(--font-serif); font-size: clamp(19px, 2.2vw, 24px); color: var(--ink); padding: 18px 0; }
  .mar-actions { list-style: none; margin: 0; padding: 0; counter-reset: action; }
  .mar-actions li { position: relative; padding: 18px 0 18px 58px; border-top: 1px solid var(--rule); line-height: 1.62; }
  .mar-actions li::before { content: counter(action); counter-increment: action; position: absolute; left: 0; top: 18px; width: 38px; height: 38px; display: grid; place-items: center; border-radius: 50%; background: var(--accent); color: #fff; font-weight: 800; }
  .mar-actions strong { display: block; color: var(--ink); margin-bottom: 3px; }
  .mar-clause { background: var(--accent-wash); border: 1px solid var(--accent-soft); border-radius: var(--radius-md); padding: 18px 20px; margin-top: 22px; }
  .mar-clause h3 { margin: 0 0 6px; font: 700 13px var(--font-sans); text-transform: uppercase; letter-spacing: .05em; color: var(--accent-deep); }
  .mar-clause p { margin: 0; line-height: 1.65; }
  .mar-why ul { padding-left: 22px; }
  .mar-why li { margin-bottom: 10px; line-height: 1.6; }
  .mar-steps { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 12px; margin: var(--gap-5) 0; }
  .mar-step { background: var(--paper-2); border: 1px solid var(--rule); border-radius: var(--radius-md); padding: 16px; }
  .mar-step time { display: block; font: 700 12px var(--font-sans); color: var(--accent-deep); text-transform: uppercase; letter-spacing: .05em; }
  .mar-step strong { display: block; margin: 5px 0; }
  .mar-step p { font-size: 13px; line-height: 1.5; margin: 0; color: var(--ink-2); }
  .mar-record { margin: var(--gap-6) 0; }
  .mar-record-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 14px; }
  .mar-record-card { display: block; text-decoration: none; background: var(--paper-2); border: 1px solid var(--rule); border-top: 4px solid var(--accent); border-radius: var(--radius-lg); padding: 19px; }
  .mar-record-card:nth-child(2) { border-top-color: var(--blue); }
  .mar-record-card:nth-child(3) { border-top-color: var(--coral); }
  .mar-record-card:hover { border-color: var(--rule-strong); }
  .mar-record-count { display: block; font-family: var(--font-serif); font-size: 38px; font-weight: 700; line-height: 1; color: var(--accent-deep); font-variant-numeric: tabular-nums; }
  .mar-record-card:nth-child(2) .mar-record-count { color: var(--blue); }
  .mar-record-card:nth-child(3) .mar-record-count { color: var(--coral); }
  .mar-record-label { display: block; margin-top: 8px; color: var(--ink); line-height: 1.45; }
  .mar-record-note { display: block; margin-top: 8px; color: var(--ink-3); font-size: 12px; line-height: 1.45; }
  .mar-record-cta { display: inline-block; margin-top: 14px; color: var(--accent-deep); font: 700 13px var(--font-sans); }
  .mar-record-card:nth-child(2) .mar-record-cta { color: var(--blue); }
  .mar-record-card:nth-child(3) .mar-record-cta { color: var(--coral); }
  .mar-record-card:hover .mar-record-cta, .mar-record-card:focus-visible .mar-record-cta { text-decoration: underline; text-underline-offset: 3px; }
  .mar-record-card:focus-visible { outline: 3px solid var(--accent); outline-offset: 3px; }

  .rr-card { background: var(--paper-2); border: 1px solid var(--rule); border-radius: var(--radius-lg); padding: 24px; margin: var(--gap-6) 0; }
  .rr-card h2 { font-family: var(--font-serif); font-weight: 500; font-size: 25px; margin: 0 0 4px; }
  .rr-count { margin: 0 0 18px; color: var(--ink-2); }
  .rr-count b { font-size: 22px; color: var(--accent-deep); font-variant-numeric: tabular-nums; }
  .rr-statement { font-family: var(--font-serif); font-size: 19px; line-height: 1.55; border-left: 3px solid var(--accent); background: var(--accent-wash); padding: 18px 20px; margin: 18px 0; }
  .rr-field { margin: 0 0 16px; }
  .rr-label { display: block; font: 600 13px var(--font-sans); margin: 0 0 5px; }
  .rr-label .opt { color: var(--ink-3); font-weight: 400; }
  .rr-input, .rr-textarea { width: 100%; background: var(--paper); color: var(--ink); border: 1px solid var(--rule-strong); border-radius: 8px; padding: 10px 12px; font: inherit; }
  .rr-textarea { min-height: 88px; resize: vertical; }
  .rr-input:focus, .rr-textarea:focus { outline: 2px solid var(--accent); outline-offset: 1px; }
  .rr-seg { display: inline-flex; flex-wrap: wrap; gap: 8px; }
  .rr-choice { display: inline-flex; }
  .rr-choice label { padding: 8px 14px; font-size: 13.5px; cursor: pointer; border: 1px solid var(--rule-strong); border-radius: 999px; background: var(--paper); }
  .rr-choice input { position: absolute; opacity: 0; pointer-events: none; }
  .rr-choice label:has(input:checked) { background: var(--accent); border-color: var(--accent); color: #fff; font-weight: 600; }
  .rr-consent { border: 1px solid var(--rule); border-radius: var(--radius-md); padding: 14px 16px; margin: 0 0 16px; }
  .rr-consent .q { font: 600 13.5px var(--font-sans); margin: 0 0 8px; }
  .rr-honey { position: absolute; left: -9999px; width: 1px; height: 1px; overflow: hidden; }
  .rr-submit, .rr-sharebtn { appearance: none; border: none; cursor: pointer; background: var(--accent); color: #fff; font: 700 14px var(--font-sans); padding: 10px 20px; border-radius: 999px; }
  .rr-submit:disabled { opacity: .6; }
  .rr-msg { margin: 12px 0 0; font-size: 13.5px; min-height: 1em; }
  .rr-msg.is-error { color: #9f3029; }
  .rr-fine { margin: 16px 0 0; padding-top: 14px; border-top: 1px solid var(--rule); font-size: 12.5px; color: var(--ink-3); line-height: 1.55; }
  .rr-done { display: none; }
  .rr-card.is-done .rr-form { display: none; }
  .rr-card.is-done .rr-done { display: block; }
  .rr-done h3 { font-family: var(--font-serif); font-size: 22px; font-weight: 500; }
  .rr-sharebar, .rr-share { display: flex; flex-wrap: wrap; align-items: center; gap: 8px; font-size: 13.5px; }
  .rr-copy { appearance: none; cursor: pointer; border: 1px solid var(--accent-soft); background: var(--accent-wash); color: var(--accent-deep); font: 600 13px var(--font-sans); padding: 6px 12px; border-radius: 999px; }
  .rr-supporters ul { list-style: none; padding: 0; display: flex; flex-wrap: wrap; gap: 8px; }
  .rr-supporters li { font-size: 13px; background: var(--paper-2); border: 1px solid var(--rule); border-radius: 999px; padding: 4px 12px; }
  @media (max-width: 900px) { .mar-grid { grid-template-columns: 1fr; } .mar-steps { grid-template-columns: 1fr 1fr; } .mar-record-grid { grid-template-columns: 1fr; } }
  @media (max-width: 560px) { .mar-steps { grid-template-columns: 1fr; } .mar-dates li { grid-template-columns: 1fr; gap: 2px; } .mar-actions li { padding-left: 48px; } }
</style>
{% endblock %}

{% block hero %}
<figure class="mar-banner">
  <img src="/images/account-or-resign-banner.jpg?v=1" alt="North Shore landscape for the Sagamok Members' Accountability Resolution." loading="eager">
</figure>
<section class="hero">
  <div class="wrap wrap--wide">
    <p class="eyebrow">Sagamok Anishnawbek · submitted to Chief and Council July 24, 2026</p>
    <h1>{{ campaign.title }}</h1>
  </div>
</section>
{% endblock %}

{% block content %}
<div class="mar-prose">
  <p class="crumb"><a href="/communities">Communities</a> › <a href="/communities/sagamok">Sagamok Anishnawbek</a> › Members' Accountability Resolution</p>

  {% set notice_body %}<strong>This non-binding member resolution was submitted through official Council channels on July 24.</strong> It requests formal Council action. It is not a Band Council Resolution, does not remove anyone from office, and is not a legal recall vote.{% endset %}
  {% include 'components/notice.html.twig' with { variant: 'caveat', body: notice_body, label: 'What this is' } only %}

  <div class="mar-update">
    <p><strong>Submission update, July 24:</strong> The six-page package was emailed to the Chief, all twelve councillors, Political Office and Council Secretariat.</p>
    <p>Signatures remain open. You can still add your name below to support the same seven requested actions while Council considers its response.</p>
  </div>

  <div class="mar-grid">
    <div>
      <span class="mar-status">Submitted to Council</span>
      <h2>The request is now in Council's hands</h2>
      <p>{{ campaign.purpose }}</p>
      <p>The resolution asks for records, an independent financial audit, correction of verified gaps, a confidential reporting route, and a recorded Council response. It makes no finding of fraud or personal wrongdoing.</p>
      <p>The submission asks Council to place the complete resolution on the July 28 agenda, record the mover, seconder, amendments, votes, recusals and absences, and publish its response and delivery dates by August 5.</p>
    </div>
    <aside class="mar-card">
      <h3>Decision calendar</h3>
      <ul class="mar-dates">
        <li><time datetime="2026-07-23">July 23</time><span>Member information session held and attendance recorded.</span></li>
        <li><time datetime="2026-07-24">July 24</time><span>Resolution package submitted through official channels.</span></li>
        <li><time datetime="2026-07-28">July 28</time><span>Requested Council agenda and recorded decision date.</span></li>
        <li><time datetime="2026-08-05">August 5</time><span>Requested written response and delivery schedule.</span></li>
      </ul>
    </aside>
  </div>

  <article class="mar-resolution" id="resolution">
    <header>
      <p class="eyebrow">Submitted resolution · July 24, 2026</p>
      <h2>{{ campaign.title }}</h2>
      <p>Sent to the Chief, all twelve councillors, Political Office and Council Secretariat</p>
    </header>

    {% for paragraph in resolution.preamble %}<p>{{ paragraph }}</p>{% endfor %}
    <p class="mar-resolved"><strong>Therefore:</strong> {{ resolution.resolved }}</p>

    <ol class="mar-actions">
      {% for action in resolution.actions %}
        <li><strong>{{ action.title }}</strong>{{ action.text }}</li>
      {% endfor %}
    </ol>

    <div class="mar-clause">
      <h3>Accountability clause</h3>
      <p>{{ resolution.accountability_clause }}</p>
    </div>
    <div class="mar-clause">
      <h3>July 23 meeting record</h3>
      <p>{{ resolution.adoption_rule }}</p>
    </div>
  </article>

  <section class="mar-why" aria-labelledby="why-h">
    {% include 'components/section_heading.html.twig' with { title: 'Why these seven actions', id: 'why-h' } only %}
    <p>The current public record confirms overlapping elected, employment, and enterprise roles. It does not yet establish the complete current Finance and Audit Committee roster or whether every required independence statement has been completed. That is why this resolution asks Council to publish the records and authorize an independent financial audit instead of declaring a violation before the evidence is complete.</p>
    <ul>
      <li><strong>Financial Administration Law section 11</strong> sets committee eligibility and independence requirements and requires written statements before appointment and annually.</li>
      <li><strong>Sections 72 to 74</strong> create reporting, inquiry, confidentiality, anti-reprisal, and safeguarding duties for suspected breaches and financial irregularities.</li>
      <li><strong>Section 75</strong> can make a councillor personally liable for voting to authorize money used contrary to the Financial Administration Law or local revenue law. It is not automatic: the vote, the legal contravention, the amount, and any statutory defence would have to be established.</li>
    </ul>
    <p><a href="https://partii-partiii.fng.ca/fng-gpn-ii-iii/pii/en/item/492567/index.do">Read Sagamok's Financial Administration Law in the First Nations Gazette.</a></p>
  </section>

  {% include 'components/section_heading.html.twig' with { title: 'From meeting to verified response', id: 'steps-h' } only %}
  <div class="mar-steps" aria-labelledby="steps-h">
    <div class="mar-step"><time>July 23</time><strong>Discuss</strong><p>Members met, heard the documented record, and asked questions.</p></div>
    <div class="mar-step"><time>July 24</time><strong>Delivered</strong><p>The seven-part resolution and support record were sent through official Council channels.</p></div>
    <div class="mar-step"><time>July 28</time><strong>Decide</strong><p>Ask Council for a recorded motion, votes, owners, and dates.</p></div>
    <div class="mar-step"><time>August 5</time><strong>Respond</strong><p>Requested deadline for Council's written response and delivery schedule.</p></div>
  </div>

  <section class="mar-record" aria-labelledby="record-h">
    {% include 'components/section_heading.html.twig' with { title: "The members' record", id: 'record-h' } only %}
    <p>Each number belongs to a different member action. They are shown together because they document sustained demand for records, an independent financial audit, and accountable government. The signature lists are not merged.</p>
    <div class="mar-record-grid">
      {% for item in members_record %}
        <a class="mar-record-card" href="{{ item.href }}"{% if item.href starts with 'http' %} target="_blank" rel="noopener"{% endif %}>
          <span class="mar-record-count" data-record-count="{{ item.id }}">{{ item.fallback_count }}</span>
          <span class="mar-record-label">{{ item.label }}</span>
          <span class="mar-record-note">{{ item.note }}</span>
          <span class="mar-record-cta">{{ item.cta }}</span>
        </a>
      {% endfor %}
    </div>
  </section>

  <section class="rr-card" id="resolution-sign-on" data-rr aria-labelledby="rr-h">
    <h2 id="rr-h">Signatures remain open</h2>
    <p>You can still add your name to support the exact seven requested actions. New signatures will remain part of the support record while Council considers its response.</p>
    <p class="rr-count" data-rr-countbox hidden>Joined by <b data-rr-count>0</b> members and supporters so far</p>
    <p class="rr-sharebar">Share this page: <button type="button" class="rr-sharebtn" data-rr-share hidden>Share</button><button type="button" class="rr-copy" data-rr-copy>Copy link</button></p>
    <p class="rr-statement">I support the seven requested actions in the {{ campaign.title }} displayed on this page.</p>
    <div class="mar-disclaimer" id="original-statement-record"><p><strong>Earlier names are not carried over.</strong> {{ campaign.consent_note }}</p></div>

    <form class="rr-form" data-rr-form novalidate>
      <div class="rr-honey" aria-hidden="true"><label>Leave blank<input type="text" name="website" tabindex="-1" autocomplete="off"></label></div>
      <div class="rr-field"><label class="rr-label" for="mar-name">Your name</label><input class="rr-input" id="mar-name" name="name" type="text" autocomplete="name" maxlength="120" required></div>
      <div class="rr-field"><label class="rr-label" for="mar-email">Email <span class="opt">(optional)</span></label><input class="rr-input" id="mar-email" name="email" type="email" autocomplete="email" maxlength="255"></div>
      <div class="rr-field">
        <span class="rr-label">I am a...</span>
        <span class="rr-seg" role="radiogroup" aria-label="Member or supporter">
          <span class="rr-choice"><label><input type="radio" name="member_flag" value="member" checked>Sagamok member</label></span>
          <span class="rr-choice"><label><input type="radio" name="member_flag" value="supporter">Supporter</label></span>
        </span>
      </div>
      <div class="rr-field"><label class="rr-label" for="mar-comment">Comment for the member record <span class="opt">(optional)</span></label><textarea class="rr-textarea" id="mar-comment" name="comment" maxlength="2000"></textarea></div>
      <div class="rr-consent">
        <p class="q">Show my name publicly on this site</p>
        <span class="rr-seg" role="radiogroup" aria-label="Show my name publicly">
          <span class="rr-choice"><label><input type="radio" name="show_name_publicly" value="yes">Yes, sign publicly</label></span>
          <span class="rr-choice"><label><input type="radio" name="show_name_publicly" value="no" checked>Count me, do not publish my name</label></span>
        </span>
      </div>
      <button class="rr-submit" type="submit" data-rr-submit>Add my name</button>
      <p class="rr-msg" data-rr-msg role="status" aria-live="polite"></p>
    </form>

    <div class="rr-done" data-rr-done aria-live="polite">
      <h3>Miigwech, your name has been added.</h3>
      <p data-rr-donecount></p>
      <p class="rr-share">Ask another member to read and sign the exact resolution. <button type="button" class="rr-sharebtn" data-rr-share hidden>Share</button><button type="button" class="rr-copy" data-rr-copy>Copy link</button></p>
      <p data-rr-removewrap hidden>Changed your mind? <a href="#" data-rr-remove>Remove my signature</a>. Keep this link private.</p>
    </div>

    <p class="rr-fine">By adding your name, you consent to the Circle storing it for this resolution. Name only, plus your email if you choose to give one, on the Circle's own servers in Canada. No band numbers and no advertising trackers. Member and supporter totals must be reported separately when the resolution is presented. You can remove your signature at any time.</p>
  </section>

  <div class="rr-supporters" data-rr-supporters hidden><h3>People who chose to be named</h3><ul data-rr-supporters-list></ul></div>
  <p class="rr-fine">Submitted to Chief and Council on July 24, 2026. Signatures remain open and the live support count will continue to be recorded separately from earlier campaigns. See also the <a href="/standard/records-request">June 2026 member records request</a> and the <a href="/communities/sagamok/conflict-register">public-record conflict register</a>.</p>
</div>
{% endblock %}

{% block scripts %}
<script>
(function () {
  var card = document.querySelector('[data-rr]');
  if (!card) return;
  var SLUG = 'sagamok-accountability-resolution-2026';
  var form = card.querySelector('[data-rr-form]');
  var msg = card.querySelector('[data-rr-msg]');
  var submit = card.querySelector('[data-rr-submit]');
  var shareUrl = location.origin + '/communities/sagamok/member-accountability-resolution';
  function fmt(n) { try { return Number(n).toLocaleString(); } catch (e) { return String(n); } }
  function setCount(n) {
    if (n === null || n === undefined) return;
    var box = card.querySelector('[data-rr-countbox]');
    var el = card.querySelector('[data-rr-count]');
    if (el) el.textContent = fmt(n);
    if (box) box.hidden = false;
  }
  function renderSupporters(recent) {
    if (!recent || !recent.length) return;
    var wrap = document.querySelector('[data-rr-supporters]');
    var list = document.querySelector('[data-rr-supporters-list]');
    if (!wrap || !list) return;
    list.innerHTML = '';
    recent.forEach(function (person) { var li = document.createElement('li'); li.textContent = person.name; list.appendChild(li); });
    wrap.hidden = false;
  }
  function setRecordCount(id, value) {
    if (value === null || value === undefined) return;
    var el = document.querySelector('[data-record-count="' + id + '"]');
    if (el) el.textContent = fmt(value);
  }
  function hydrateMemberRecord() {
    // Local development uses a separate SQLite file whose historical campaign
    // rows do not mirror production. Keep the verified source fallbacks in a
    // local preview; production hydrates from its own live campaign records.
    if (location.hostname === '127.0.0.1' || location.hostname === 'localhost') return;
    [
      ['original_statement', 'account-or-resign'],
      ['records_request', 'records-request-support']
    ].forEach(function (item) {
      fetch('/api/petition/' + item[1], { headers: { Accept: 'application/json' } })
        .then(function (r) { return r.ok ? r.json() : null; })
        .then(function (d) { if (d && d.ok) setRecordCount(item[0], d.count); })
        .catch(function () {});
    });
  }
  fetch('/api/petition/' + SLUG, { headers: { Accept: 'application/json' } })
    .then(function (r) { return r.ok ? r.json() : null; })
    .then(function (d) { if (d && d.ok) { setCount(d.count); renderSupporters(d.recent); } })
    .catch(function () {});
  hydrateMemberRecord();
  function checked(name) { var el = form.querySelector('input[name="' + name + '"]:checked'); return el ? el.value : ''; }
  form.addEventListener('submit', function (event) {
    event.preventDefault();
    if (msg) { msg.textContent = ''; msg.classList.remove('is-error'); }
    var payload = {
      campaign: SLUG,
      name: (form.elements.name || {}).value || '',
      email: (form.elements.email || {}).value || '',
      member_flag: checked('member_flag') || 'supporter',
      comment: (form.elements.comment || {}).value || '',
      include_name_on_letter: false,
      show_name_publicly: checked('show_name_publicly') === 'yes',
      consent: true,
      website: (form.elements.website || {}).value || ''
    };
    if (!payload.name.trim()) { if (msg) { msg.textContent = 'Please enter your name.'; msg.classList.add('is-error'); } return; }
    if (submit) { submit.disabled = true; submit.textContent = 'Adding...'; }
    fetch('/api/petition/sign', { method: 'POST', headers: { 'Content-Type': 'application/json', Accept: 'application/json' }, body: JSON.stringify(payload) })
      .then(function (r) { return r.json(); })
      .then(function (res) {
        if (!res || !res.ok) {
          if (msg) { msg.textContent = (res && res.error) || 'Something went wrong. Please try again.'; msg.classList.add('is-error'); }
          if (submit) { submit.disabled = false; submit.textContent = 'Add my name'; }
          return;
        }
        card.classList.add('is-done'); setCount(res.count);
        var doneCount = card.querySelector('[data-rr-donecount]');
        if (doneCount && res.count != null) doneCount.textContent = 'You are one of ' + fmt(res.count) + ' so far.';
        var removeWrap = card.querySelector('[data-rr-removewrap]');
        var removeLink = card.querySelector('[data-rr-remove]');
        if (removeWrap && removeLink && res.manage_url) { removeLink.href = res.manage_url; removeWrap.hidden = false; }
      })
      .catch(function () { if (msg) { msg.textContent = 'Could not reach the server. Please try again.'; msg.classList.add('is-error'); } if (submit) { submit.disabled = false; submit.textContent = 'Add my name'; } });
  });
  function copyLink(button) {
    var original = button.textContent;
    function ok() { button.textContent = 'Link copied'; setTimeout(function () { button.textContent = original; }, 2000); }
    if (navigator.clipboard && navigator.clipboard.writeText) navigator.clipboard.writeText(shareUrl).then(ok).catch(function () { window.prompt('Copy this link:', shareUrl); });
    else window.prompt('Copy this link:', shareUrl);
  }
  card.querySelectorAll('[data-rr-copy]').forEach(function (button) { button.addEventListener('click', function () { copyLink(button); }); });
  if (navigator.share) card.querySelectorAll('[data-rr-share]').forEach(function (button) { button.hidden = false; button.addEventListener('click', function () { navigator.share({ title: "Sagamok Members' Accountability Resolution", text: 'Read the exact non-binding member resolution proposed for July 23.', url: shareUrl }).catch(function () {}); }); });
})();
</script>
{% endblock %}
