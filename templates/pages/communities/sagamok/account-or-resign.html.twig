{% extends 'base.html.twig' %}
{% set nav = 'communities' %}

{% block title %}Account, or Resign: a member statement · Robinson Huron Treaty{% endblock %}
{% block description %}A member-authored statement of no confidence in Sagamok's current Chief and Council, calling on them to account fully to the members within thirty days, or resign. Members can add their name, publicly or to be counted only.{% endblock %}
{% block og_description %}Members of Sagamok Anishnawbek state that they have lost confidence in the current Chief and Council, and call on them to account fully, or resign.{% endblock %}
{% block body_class %}route-sagamok-account-or-resign{% endblock %}

{% block head_styles %}
<style>
  /* Statement body + reused sign-card (.aor-stmt is page-local prose framing;
     .rr-* is the shared petition sign-card, same tokens/markup as the
     records-request page, just a different campaign slug in the script). */
  .aor-stmt p { max-width: 74ch; line-height: 1.65; margin: 0 0 var(--gap-4); }
  .aor-stmt .lead { font-family: var(--font-serif); font-size: clamp(18px, 2vw, 21px); line-height: 1.55; color: var(--ink); }
  .aor-ask { margin: var(--gap-5) 0; background: var(--accent-wash); border: 1px solid var(--accent-soft); border-left: 4px solid var(--accent); border-radius: var(--radius-md); padding: 20px 24px; }
  .aor-ask h3 { font-family: var(--font-sans); font-size: 13px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--accent-deep); margin: 0 0 10px; }
  .aor-ask ol { margin: 0; padding-left: 22px; max-width: 74ch; }
  .aor-ask li { margin: 0 0 12px; line-height: 1.6; color: var(--ink-2); }
  .aor-ask li b { color: var(--ink); }
  .aor-ask li:last-child { margin-bottom: 0; }

  /* Sign-on card, ported verbatim from the records-request page (.rr-*). */
  .rr-card { background: var(--paper-2); border: 1px solid var(--rule); border-radius: var(--radius-lg); padding: 24px 24px 26px; margin: var(--gap-6) 0; }
  .rr-card h2 { font-family: var(--font-serif); font-weight: 500; font-size: 22px; margin: 0 0 4px; color: var(--ink); }
  .rr-count { margin: 0 0 18px; font-size: 15px; color: var(--ink-2); }
  .rr-count b { font-family: var(--font-sans); font-size: 22px; font-weight: 700; color: var(--accent-deep); font-variant-numeric: tabular-nums; }
  .rr-paper { margin: -12px 0 18px; font-size: 13px; line-height: 1.5; color: var(--ink-3); max-width: none; }
  .rr-statement { font-family: var(--font-serif); font-size: clamp(18px, 2vw, 22px); line-height: 1.5; color: var(--ink); border-left: 3px solid var(--accent); background: var(--accent-wash); padding: 18px 22px; border-radius: 0 var(--radius-md) var(--radius-md) 0; margin: 0 0 var(--gap-5); max-width: none; }
  .rr-field { margin: 0 0 16px; }
  .rr-label { display: block; font-family: var(--font-sans); font-size: 13px; font-weight: 600; color: var(--ink); margin: 0 0 5px; }
  .rr-label .opt { color: var(--ink-3); font-weight: 400; }
  .rr-input, .rr-textarea { width: 100%; background: var(--paper); color: var(--ink); border: 1px solid var(--rule-strong); border-radius: 8px; padding: 10px 12px; font: inherit; }
  .rr-textarea { min-height: 88px; resize: vertical; }
  .rr-input:focus, .rr-textarea:focus { outline: 2px solid var(--accent); outline-offset: 1px; border-color: var(--accent); }
  .rr-seg { display: inline-flex; flex-wrap: wrap; gap: 8px; }
  .rr-choice { display: inline-flex; }
  .rr-choice label { display: inline-block; padding: 8px 14px; font-size: 13.5px; cursor: pointer; color: var(--ink-2); border: 1px solid var(--rule-strong); border-radius: 999px; background: var(--paper); }
  .rr-choice input { position: absolute; opacity: 0; pointer-events: none; }
  .rr-choice label:has(input:checked) { background: var(--accent); border-color: var(--accent); color: #fff; font-weight: 600; }
  .rr-consent { border: 1px solid var(--rule); border-radius: var(--radius-md); padding: 14px 16px; margin: 0 0 16px; }
  .rr-consent .q { font-family: var(--font-sans); font-size: 13.5px; font-weight: 600; color: var(--ink); margin: 0 0 8px; max-width: none; }
  .rr-honey { position: absolute; left: -9999px; width: 1px; height: 1px; overflow: hidden; }
  .rr-submit { -webkit-appearance: none; appearance: none; border: none; cursor: pointer; background: var(--accent); color: #fff; font-family: var(--font-sans); font-size: 15px; font-weight: 700; padding: 12px 24px; border-radius: 999px; }
  .rr-submit:disabled { opacity: 0.6; cursor: default; }
  .rr-msg { margin: 12px 0 0; font-size: 13.5px; min-height: 1em; max-width: none; }
  .rr-msg.is-error { color: oklch(0.55 0.16 25); }
  .rr-fine { margin: 16px 0 0; padding-top: 14px; border-top: 1px solid var(--rule); font-size: 12.5px; color: var(--ink-3); line-height: 1.55; max-width: none; }
  .rr-done { display: none; }
  .rr-card.is-done .rr-form { display: none; }
  .rr-card.is-done .rr-done { display: block; }
  .rr-done h3 { font-family: var(--font-serif); font-size: 22px; font-weight: 500; color: var(--ink); margin: 0 0 8px; border: none; padding: 0; text-transform: none; letter-spacing: 0; }
  .rr-remove { color: var(--ink-3); font-size: 12.5px; max-width: none; }
  .rr-remove a { color: var(--accent-deep); }
  .rr-share { margin: 14px 0 0; font-size: 14px; color: var(--ink-2); max-width: none; }
  .rr-copy { -webkit-appearance: none; appearance: none; cursor: pointer; border: 1px solid var(--accent-soft); background: var(--accent-wash); color: var(--accent-deep); font: inherit; font-size: 13px; font-weight: 600; padding: 5px 12px; border-radius: 999px; margin-left: 4px; }
  .rr-copy:hover { border-color: var(--accent); }
  .rr-sharebar { margin: 0 0 18px; font-size: 13.5px; color: var(--ink-2); display: flex; flex-wrap: wrap; align-items: center; gap: 8px 10px; max-width: none; }
  .rr-card.is-done .rr-sharebar { display: none; }
  .rr-sharebtn { -webkit-appearance: none; appearance: none; cursor: pointer; border: none; background: var(--accent); color: #fff; font: inherit; font-size: 13px; font-weight: 700; padding: 6px 16px; border-radius: 999px; display: inline-flex; align-items: center; gap: 6px; }
  .rr-sharebtn:hover { filter: brightness(1.05); }
  .rr-supporters { margin: var(--gap-5) 0 0; max-width: 820px; }
  .rr-supporters h3 { font-family: var(--font-sans); font-size: 12px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-3); margin: 0 0 10px; border: none; padding: 0; }
  .rr-supporters ul { list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: 8px; }
  .rr-supporters li { font-size: 13px; color: var(--ink-2); background: var(--paper-2); border: 1px solid var(--rule); border-radius: 999px; padding: 4px 12px; }
</style>
{% endblock %}

{% block content %}
  <p class="crumb"><a href="/communities">Communities</a> › <a href="/communities/sagamok">Sagamok Anishnawbek</a> › Account, or Resign</p>

  <p class="eyebrow">Sagamok Anishnawbek · A statement from the members</p>
  <h1>Account, or Resign</h1>

  {% set banner_body %}<strong>A member-authored statement, hosted and carried by the Circle.</strong> This is not the Circle's own characterization of any person; it is a statement members chose to write and sign, reproduced here as written. <a href="/about#corrections">Tell us what we got wrong</a> and we will correct it.{% endset %}
  {% include 'components/notice.html.twig' with { variant: 'caveat', body: banner_body, label: 'About this statement' } only %}

  <div class="aor-stmt">
    <p>We are members of Sagamok Anishnawbek. We are writing together because we have lost confidence in our Chief and Council, and because we have no other way to say so that carries any weight. Our election law provides members no means to remove leadership between elections. That silence in the law is exactly why this statement is necessary.</p>

    <p>We do not make this statement lightly. We come to it with different feelings. Some of us are angry. Some are disappointed. Some are worried. Some are confused. Some are simply tired of asking and getting no answer. What unites us is not a mood, it is the record. Here is what that record shows.</p>

    <p>We asked for answers, and received none. On June 10, 2026, members submitted a formal records request to Chief and Council, signed by more than one hundred members, asking for specific documents tied to specific decisions. We asked for a response within thirty days. That period closed on July 10 with no records, no accounting, and no substantive reply.</p>

    <p>Our settlement is not accounted for to us. The Nation holds a settlement trust of roughly $219 million (BMO, December 2025). We want to be fair and clear about this: the most recent audit is clean, and our concern is transparency, not a verdict. But members still cannot see the basic answers. Where is the trust held, and who can authorize moving it? What return does it earn for the members? And by the Nation's own audited statements, about $97 million of our settlement was loaned to the Nation's own businesses, on terms that are not made public. We have asked these questions. We have not been answered.</p>

    <p>Decisions are made without us. Major commitments, including the long-term care Memorandum of Understanding and a series of enterprise and lending decisions, have been made in closed session and disclosed to members late or not at all, without consultation.</p>

    <p>Power and pay are concentrated in a few hands. By the Nation's own public record, thirteen elected people hold more than fifty paid roles between them. Councillors draw salaries as employees of the same administration they are elected to oversee, and the honourariums and committee appointments are not made public.</p>

    <p>And we cannot remove them. There is no recall, no-confidence, or removal provision available to members in our election law, and none in force under the federal Act either. Between now and the next election, members have been left with no formal accountability at all.</p>

    <p>For these reasons, we, the undersigned members of Sagamok Anishnawbek, declare that we have lost confidence in the current Chief and Council, and we call on them to choose one of two honourable paths:</p>
  </div>

  <div class="aor-ask">
    <h3>Two paths</h3>
    <ol>
      <li><b>Account to the members.</b> Release the records that were requested, provide a full and detailed accounting of the settlement trust and the returns it earns for members, publish the roles, pay, honourariums, and committee appointments of every Council member, and commit to member consultation on major decisions, within thirty days of this statement.</li>
      <li><b>Or resign.</b> If our leadership will not account to the members, then it has lost the mandate to govern them, and the honourable course is to step down and let the community choose leadership that will.</li>
    </ol>
  </div>

  <div class="aor-stmt">
    <p>We also call for a member-led community meeting, open to all members, so that the membership can hear one another and speak with one voice.</p>

    <p>This is a call for accountability, not an accusation against any person. We seek the truth and the records, and we seek a leadership that answers to its members.</p>
  </div>

  <section class="rr-card" data-rr aria-labelledby="rr-h">
    <h2 id="rr-h">Add your name</h2>
    <p class="rr-count" data-rr-countbox hidden>Joined by <b data-rr-count>0</b> members and supporters so far</p>
    <p class="rr-paper" data-rr-paper hidden></p>

    <p class="rr-sharebar">Share this page:
      <button type="button" class="rr-sharebtn" data-rr-share hidden>Share</button>
      <button type="button" class="rr-copy" data-rr-copy>Copy link</button>
    </p>

    <form class="rr-form" data-rr-form novalidate>
      <div class="rr-honey" aria-hidden="true"><label>Leave blank<input type="text" name="website" tabindex="-1" autocomplete="off"></label></div>

      <div class="rr-field">
        <label class="rr-label" for="aor-name">Your name</label>
        <input class="rr-input" id="aor-name" name="name" type="text" autocomplete="name" maxlength="120" required>
      </div>

      <div class="rr-field">
        <label class="rr-label" for="aor-email">Email <span class="opt">(optional)</span></label>
        <input class="rr-input" id="aor-email" name="email" type="email" autocomplete="email" maxlength="255">
      </div>

      <div class="rr-field">
        <span class="rr-label">I am a...</span>
        <span class="rr-seg" role="radiogroup" aria-label="Member or supporter">
          <span class="rr-choice"><label><input type="radio" name="member_flag" value="member" checked>Sagamok member</label></span>
          <span class="rr-choice"><label><input type="radio" name="member_flag" value="supporter">Supporter</label></span>
        </span>
      </div>

      <div class="rr-field">
        <label class="rr-label" for="aor-comment">A concern, question, or experience you want included <span class="opt">(optional)</span></label>
        <textarea class="rr-textarea" id="aor-comment" name="comment" maxlength="2000"></textarea>
      </div>

      <div class="rr-consent">
        <p class="q">Show my name publicly on this site</p>
        <span class="rr-seg" role="radiogroup" aria-label="Show my name publicly">
          <span class="rr-choice"><label><input type="radio" name="show_name_publicly" value="yes">Yes, sign publicly</label></span>
          <span class="rr-choice"><label><input type="radio" name="show_name_publicly" value="no" checked>Count me, do not publish my name</label></span>
        </span>
      </div>

      <button class="rr-submit" type="submit" data-rr-submit>Add my name</button>
      <p class="rr-msg" data-rr-msg role="status" aria-live="polite"></p>
    </form>

    <div class="rr-done" data-rr-done aria-live="polite">
      <h3>Miigwech, your name has been added.</h3>
      <p data-rr-donecount></p>
      <p class="rr-share">Help it grow: ask another member to add their name. <button type="button" class="rr-sharebtn" data-rr-share hidden>Share</button> <button type="button" class="rr-copy" data-rr-copy>Copy link to share</button></p>
      <p class="rr-remove" data-rr-removewrap hidden>Changed your mind? <a href="#" data-rr-remove>Remove my signature</a>. Keep this link private to you.</p>
    </div>

    <p class="rr-fine">By adding your name you consent to the Circle storing it to present this statement to Chief and Council. Name only (plus your email if you choose to give one), on the Circle's own servers in Canada. No band numbers, no trackers. The Circle is independent of Chief and Council. You can remove yours anytime. This signature count is kept separate from the records-request count; the two are different statements.</p>
  </section>

  <div class="rr-supporters" data-rr-supporters hidden>
    <h3>Supporters who chose to be named</h3>
    <ul data-rr-supporters-list></ul>
  </div>

  <p class="rr-fine">Published July 11, 2026. See also: <a href="/standard/records-request">the member records request</a> this statement follows up on, and <a href="/communities/sagamok/one-seat-one-salary">Paid at every table</a>, the sourced record of roles and pay behind this statement.</p>
{% endblock %}

{% block scripts %}
<script>
  (function () {
    var card = document.querySelector('[data-rr]');
    if (!card) return;
    var SLUG = 'account-or-resign';
    var form = card.querySelector('[data-rr-form]');
    var msg = card.querySelector('[data-rr-msg]');
    var submit = card.querySelector('[data-rr-submit]');

    function fmt(n) { try { return Number(n).toLocaleString(); } catch (e) { return String(n); } }

    function setCount(n) {
      if (n === null || n === undefined) return;
      var box = card.querySelector('[data-rr-countbox]');
      var el = card.querySelector('[data-rr-count]');
      if (el) el.textContent = fmt(n);
      if (box) box.hidden = false;
    }

    function setPaper(count, note) {
      if (!count || !note) return;
      var el = card.querySelector('[data-rr-paper]');
      if (el) { el.textContent = note; el.hidden = false; }
    }

    function renderSupporters(recent) {
      if (!recent || !recent.length) return;
      var wrap = document.querySelector('[data-rr-supporters]');
      var list = document.querySelector('[data-rr-supporters-list]');
      if (!wrap || !list) return;
      list.innerHTML = '';
      recent.forEach(function (s) {
        var li = document.createElement('li');
        li.textContent = s.name;
        list.appendChild(li);
      });
      wrap.hidden = false;
    }

    function hydrate() {
      fetch('/api/petition/' + SLUG, { headers: { 'Accept': 'application/json' } })
        .then(function (r) { return r.ok ? r.json() : null; })
        .then(function (d) { if (d && d.ok) { setCount(d.count); setPaper(d.paper_count, d.paper_note); renderSupporters(d.recent); } })
        .catch(function () {});
    }

    function checked(name) {
      var el = form.querySelector('input[name="' + name + '"]:checked');
      return el ? el.value : '';
    }

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      if (msg) { msg.textContent = ''; msg.classList.remove('is-error'); }

      var payload = {
        campaign: SLUG,
        name: (form.elements['name'] || {}).value || '',
        email: (form.elements['email'] || {}).value || '',
        member_flag: checked('member_flag') || 'supporter',
        comment: (form.elements['comment'] || {}).value || '',
        include_name_on_letter: false,
        show_name_publicly: checked('show_name_publicly') === 'yes',
        consent: true,
        website: (form.elements['website'] || {}).value || ''
      };

      if (!payload.name.trim()) {
        if (msg) { msg.textContent = 'Please enter your name.'; msg.classList.add('is-error'); }
        return;
      }
      if (submit) { submit.disabled = true; submit.textContent = 'Adding...'; }

      fetch('/api/petition/sign', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify(payload)
      })
        .then(function (r) { return r.json().then(function (b) { return b; }); })
        .then(function (res) {
          if (!res || !res.ok) {
            if (msg) { msg.textContent = (res && res.error) || 'Something went wrong. Please try again.'; msg.classList.add('is-error'); }
            if (submit) { submit.disabled = false; submit.textContent = 'Add my name'; }
            return;
          }
          card.classList.add('is-done');
          setCount(res.count);
          var dc = card.querySelector('[data-rr-donecount]');
          if (dc && res.count != null) dc.textContent = 'You are one of ' + fmt(res.count) + ' so far.';
          var rw = card.querySelector('[data-rr-removewrap]');
          var rl = card.querySelector('[data-rr-remove]');
          if (rw && rl && res.manage_url) { rl.setAttribute('href', res.manage_url); rw.hidden = false; }
        })
        .catch(function () {
          if (msg) { msg.textContent = 'Could not reach the server. Please try again.'; msg.classList.add('is-error'); }
          if (submit) { submit.disabled = false; submit.textContent = 'Add my name'; }
        });
    });

    var shareUrl = location.origin + '/communities/sagamok/account-or-resign';

    function copyLink(btn) {
      var orig = btn.getAttribute('data-orig') || btn.textContent;
      btn.setAttribute('data-orig', orig);
      var ok = function () { btn.textContent = 'Link copied'; setTimeout(function () { btn.textContent = orig; }, 2000); };
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(shareUrl).then(ok).catch(function () { window.prompt('Copy this link:', shareUrl); });
      } else {
        window.prompt('Copy this link:', shareUrl);
      }
    }

    function nativeShare() {
      if (!navigator.share) return;
      navigator.share({
        title: 'Account, or Resign: a member statement',
        text: 'Members of Sagamok Anishnawbek call on Chief and Council to account fully, or resign.',
        url: shareUrl
      }).catch(function () {});
    }

    card.querySelectorAll('[data-rr-copy]').forEach(function (btn) {
      btn.addEventListener('click', function () { copyLink(btn); });
    });

    if (navigator.share) {
      card.querySelectorAll('[data-rr-share]').forEach(function (btn) {
        btn.hidden = false;
        btn.addEventListener('click', nativeShare);
      });
    }

    hydrate();
  })();
</script>
{% endblock %}
