{% block content %}
<article class="rrl-wrap">
  <p class="eyebrow">The shared standard, in practice</p>
  <h1>Member records request to Chief and Council</h1>

  <p style="margin: 0 0 var(--gap-5); font-family: var(--font-sans); font-size: 14px; font-weight: 600; color: var(--accent-deep);">Status: open and growing. The records request was submitted to Chief and Council, through the Council Secretariat, on June 10, 2026, with a response requested within 30 days. It stays open: members and supporters can still add their names, and updated signature lists will continue to be provided to Council.</p>

  <p class="rr-statement">We, the undersigned members of Sagamok Anishnawbek, support the records request submitted to Chief and Council. We want clear answers, on the record, to one question: when the Nation invests in businesses and ventures, what are the benefits to the membership, and who is being served? We ask Council to provide the records and respond to the membership.</p>

  <p class="muted">Here about school funding? Band post-secondary money is only one door, and it is not the only way to pay for college, university, or the trades. See <a href="/resources/paying-for-school">Paying for school</a> for the funding paths a member can use, most of which can be combined.</p>

  <figure class="rr-illus">
    <img src="/images/records-request-illustration.png" width="1264" height="842" loading="lazy" decoding="async"
         alt="Illustration of community members outside the Sagamok Anishnawbek Multi-Educational Centre holding Release Our Records signs, one figure for each signature collected.">
    <figcaption>Illustration: 61 people, one for every member who has signed so far.</figcaption>
  </figure>

  <section class="rr-card" data-rr aria-labelledby="rr-h">
    <h2 id="rr-h">Add your name</h2>
    <p class="rr-count" data-rr-countbox hidden>Joined by <b data-rr-count>0</b> members and supporters so far</p>
    <p class="rr-paper" data-rr-paper hidden></p>

    <p class="rr-sharebar">Share this page:
      <button type="button" class="rr-sharebtn" data-rr-share hidden>Share</button>
      <button type="button" class="rr-copy" data-rr-copy>Copy link</button>
    </p>

    <form class="rr-form" data-rr-form novalidate>
      <div class="rr-honey" aria-hidden="true"><label>Leave blank<input type="text" name="website" tabindex="-1" autocomplete="off"></label></div>

      <div class="rr-field">
        <label class="rr-label" for="rr-name">Your name</label>
        <input class="rr-input" id="rr-name" name="name" type="text" autocomplete="name" maxlength="120" required>
      </div>

      <div class="rr-field">
        <label class="rr-label" for="rr-email">Email <span class="opt">(optional)</span></label>
        <input class="rr-input" id="rr-email" name="email" type="email" autocomplete="email" maxlength="255">
      </div>

      <div class="rr-field">
        <span class="rr-label">I am a...</span>
        <span class="rr-seg" role="radiogroup" aria-label="Member or supporter">
          <span class="rr-choice"><label><input type="radio" name="member_flag" value="member" checked>Sagamok member</label></span>
          <span class="rr-choice"><label><input type="radio" name="member_flag" value="supporter">Supporter</label></span>
        </span>
      </div>

      <div class="rr-field">
        <label class="rr-label" for="rr-comment">A concern, question, or experience you want included <span class="opt">(optional)</span></label>
        <textarea class="rr-textarea" id="rr-comment" name="comment" maxlength="2000"></textarea>
      </div>

      <div class="rr-consent">
        <p class="q">Include my name on the letter to Chief and Council</p>
        <span class="rr-seg" role="radiogroup" aria-label="Include my name on the letter">
          <span class="rr-choice"><label><input type="radio" name="include_name_on_letter" value="yes">Yes, include my name</label></span>
          <span class="rr-choice"><label><input type="radio" name="include_name_on_letter" value="no" checked>Count me only, do not name me</label></span>
        </span>
      </div>

      <div class="rr-consent">
        <p class="q">Show my name publicly on this site</p>
        <span class="rr-seg" role="radiogroup" aria-label="Show my name publicly">
          <span class="rr-choice"><label><input type="radio" name="show_name_publicly" value="yes">Yes</label></span>
          <span class="rr-choice"><label><input type="radio" name="show_name_publicly" value="no" checked>No</label></span>
        </span>
      </div>

      <button class="rr-submit" type="submit" data-rr-submit>Add my name</button>
      <p class="rr-msg" data-rr-msg role="status" aria-live="polite"></p>
    </form>

    <div class="rr-done" data-rr-done aria-live="polite">
      <h3>Miigwech, your name has been added.</h3>
      <p data-rr-donecount></p>
      <p class="rr-share">Help it grow: ask another member to add their name. <button type="button" class="rr-sharebtn" data-rr-share hidden>Share</button> <button type="button" class="rr-copy" data-rr-copy>Copy link to share</button></p>
      <p class="rr-remove" data-rr-removewrap hidden>Changed your mind? <a href="#" data-rr-remove>Remove my signature</a>. Keep this link private to you.</p>
    </div>

    <p class="rr-fine">By adding your name you consent to the Circle storing it to present this support to Chief and Council. Name only (plus your email if you choose to give one), on the Circle's own servers in Canada. No band numbers, no trackers. The Circle is independent of Chief and Council. You can remove yours anytime.</p>
  </section>

  <div class="rr-supporters" data-rr-supporters hidden>
    <h3>Supporters who chose to be named</h3>
    <ul data-rr-supporters-list></ul>
  </div>

  <div class="rrl-about">
    <p><strong>About this document.</strong> This is the full text of a records request that a member of Sagamok Anishnawbek filed with Chief and Council on June 10, 2026, reproduced here as it was filed. It is one member's request, carried by the Circle as a worked example of the shared standard in practice. We publish it as a primary record of what members asked for, not as the Circle's own characterization of any person. The names and the board table below appear exactly as they did in the filed request, drawn from public corporate registries and the Nation's own records. The Circle works from sourced facts and names no private individuals in the pages it writes in its own voice. This page is different in kind: it faithfully reproduces a civic document that a member chose to file and sign.</p>
  </div>

  <p class="rrl-meta">Submitted to Chief and Council, c/o the Council Secretariat, on June 10, 2026.</p>
  <p class="rrl-meta"><b>To:</b> Chief and Council, Sagamok Anishnawbek<br>
  <b>c/o</b> Office of the Council Secretariat<br>
  (delivered by mail and email)</p>
  <p class="rrl-meta"><b>From:</b> A member of Sagamok Anishnawbek</p>

  <p class="rrl-re">Re: Member records request: what are the benefits of the Nation's investments, and who is being served?</p>

  <p>Aanii,</p>

  <p>As a member of Sagamok Anishnawbek, I am writing to ask a question that many members are asking, and to request the records that would answer it. When the Nation invests in businesses and ventures, <b>what exactly are the benefits to the membership, and who is being served?</b> Leadership has consistently described these investments as benefiting the community. I would like to understand, from the Nation's own records, how that benefit is defined, measured, and delivered.</p>

  <p>The Governance Department's published mandate commits the Nation to "systems that demonstrate accountability and transparency to Chief, Council, and Sagamok Anishnawbek," and this request is made in that spirit. Each item below is tied to a specific source, the Nation's audited financial statements, its Financial Administration Law and policies, the public corporate registry, or a Council motion or resolution, and the records this request draws on are listed under "Basis for this request" at the end, so that what I am asking for is concrete and verifiable rather than a matter of opinion.</p>

  <p>The reason for these questions is itself in the public record. The people who govern the Nation also sit on the boards of the companies it invests in, and several hold paid staff roles as well. The table below sets out who sits where, with each seat tied to its source. I draw no conclusion from it. I am asking for the records that would show what benefit flows back to members from these arrangements.</p>

  <div class="rrl-matrix-wrap">
    <table class="rrl-matrix">
      <thead><tr><th class="nm">Councillor</th><th>ZEI</th><th>GR Truss</th><th>Ritchie Falls</th><th>Sagamok Real Estate</th><th>Manitoulin Hotel</th><th>SDC / SPV</th><th>Band staff role</th><th>Roles</th></tr></thead>
      <tbody>
        <tr><td class="nm">Arnelda Bennett</td><td class="d">&#9679;</td><td></td><td></td><td class="d">&#9679;</td><td class="d">&#9679;</td><td></td><td class="d">&#9679;</td><td class="cnt">4</td></tr>
        <tr><td class="nm">Michael Abitong</td><td></td><td class="d">&#9679;</td><td class="d">&#9679;</td><td></td><td></td><td class="d">&#9679;</td><td class="d">&#9679;</td><td class="cnt">4</td></tr>
        <tr><td class="nm">Norma Petahtegoose</td><td class="d">&#9679;</td><td class="d">&#9679;</td><td></td><td class="d">&#9679;</td><td></td><td></td><td></td><td class="cnt">3</td></tr>
        <tr><td class="nm">Leroy Bennett</td><td class="d">&#9679;</td><td></td><td></td><td></td><td></td><td class="d">&#9679;</td><td class="d">&#9679;</td><td class="cnt">3</td></tr>
        <tr><td class="nm">Paul Eshkakogan <span class="role2">(ZEI President)</span></td><td class="d">&#9679;</td><td></td><td></td><td></td><td></td><td class="d">&#9679;</td><td></td><td class="cnt">2</td></tr>
        <tr><td class="nm">Dan Owl</td><td></td><td></td><td></td><td class="d">&#9679;</td><td></td><td></td><td class="d">&#9679;</td><td class="cnt">2</td></tr>
        <tr><td class="nm">McKenzie Toulouse</td><td></td><td></td><td></td><td></td><td></td><td class="d">&#9679;</td><td></td><td class="cnt">1</td></tr>
        <tr><td class="nm">Nelson Toulouse</td><td class="d">&#9679;</td><td></td><td></td><td></td><td></td><td></td><td></td><td class="cnt">1</td></tr>
        <tr><td class="nm">Lawrence Solomon Sr.</td><td class="d">&#9679;</td><td></td><td></td><td></td><td></td><td></td><td></td><td class="cnt">1</td></tr>
        <tr><td class="nm">Angus Toulouse <span class="role2">(Chief)</span></td><td></td><td class="d">&#9679;</td><td></td><td></td><td></td><td></td><td></td><td class="cnt">1</td></tr>
        <tr><td class="nm">Sadie Southwind</td><td></td><td></td><td></td><td></td><td></td><td></td><td class="d">&#9679;</td><td class="cnt">1</td></tr>
        <tr><td class="nm">Conrad Toulouse</td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td class="cnt">?</td></tr>
        <tr><td class="nm">Veronica Nashkawa</td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td class="cnt">0</td></tr>
      </tbody>
    </table>
  </div>
  <p class="rrl-srcnote">Sources by column: ZEI board, zgamok.ca; GR Truss and Ritchie Falls, the Ontario Business Registry; Sagamok Real Estate and Manitoulin Hotel, Council minutes and Band Council Resolutions; band staff role, the FNFTA Schedule of Remuneration and the Nation's staff directory. SDC / SPV is the board of Sagamok Development Corporation, which is also the board of 15558409 Canada Ltd, the federal company that is the general partner of Sagamok Real Estate Holdings LP; that board also includes Nicole Eshkakogan, a former councillor (source: Corporations Canada and the Ontario Business Registry). A blank means not documented, not that no one serves; "?" means a role may exist but is not documented here; "0" means none found.</p>

  <p>I would be grateful for copies of, or supervised access to, the following. Where a document cannot be released in full, I would appreciate a written explanation of why, and of any redactions.</p>

  <h3>Benefit to members, and the investments behind it</h3>
  <ol class="rrl-list">
    <li><b>Benefit to the membership.</b> The Nation's criteria for how members benefit from its enterprise investments, and a plain accounting of the return or benefit that has actually reached members (jobs, dividends, distributions, services) set against the funds committed, including the approximately $97 million in loans to the Nation's Government Business Enterprises reported in the FY2025 audited statements (Note 14, at interest rates of 4% to 12%). The table above shows how closely Council and these companies' boards overlap, which is why a clear accounting of the benefit that reaches members matters.</li>
    <li><b>The Sault Ste. Marie urban housing investment.</b> The complete investment agreement and supporting documentation for the staged commitments that grew to approximately $7 million (Motion 2024/10 #07; BCR 2024-05-69; BCR 2025-12-80, Build Canada Homes), including the rate of return, security, and repayment terms (for comparison, the enterprise facility approved at the same meeting carried a rate of "not less than 4%"); the identity of the developer or counterparty; and any due diligence or independent valuation done before the commitment.</li>
    <li><b>The Manitoulin Hotel interest.</b> The complete record of the Nation's interest in the Manitoulin Hotel: any acquisition, and any sale or transfer of shares, with dates, price, terms, counterparties, and current status. The Manitoulin Hotel appears in Council minutes but is not listed among the Nation's consolidated entities in the FY2025 audited financial statements, which leaves open what was bought or sold and on what terms.</li>
    <li><b>GR Truss (2262012 Ontario Limited).</b> The acquisition terms (price and vendor), the business case and purpose of the Nation's involvement, how many Sagamok members the company employs, and the expected and actual benefit to the membership. (2262012 Ontario Limited is the company operating as GR Truss per the Ontario Business Registry; the Nation's involvement was ratified by Council in 2025.)</li>
    <li><b>The off-reserve real-estate structure.</b> The corporate structure and governing documents of 15558409 Canada Ltd (the federal company whose directors are the SDC board) and Sagamok Real Estate Holdings LP, including the limited partners and the source of the partnership's capital (the LP's registered Declaration lists only the general partner), the documents establishing this structure under BCR 2023-11-40, and clarification of how the "Sagamok Real Estate Co." board appointed by BCR 2025-05-59 relates to Sagamok Real Estate Holdings LP. Per the FY2025 audited statements (Note 18), GR Truss was acquired through 15558409 Canada Ltd and Sagamok Real Estate Holdings LP.</li>
    <li><b>Loans to Government Business Enterprises.</b> A list of these loans by enterprise, with the amount, interest rate, security, and repayment terms of each, and the Council authorization for them.</li>
    <li><b>Investment, borrowing and for-profit policies.</b> Any policy or criteria governing the investment of Nation or settlement funds, including off-reserve, and any framework referenced in BCR 2023-11-40; the borrowing policy required under Financial Administration Law section 36; the for-profit risk-management policy required under section 40; and any director-of-finance risk reports for guarantees under section 41. If any of these do not exist in writing, I would appreciate confirmation of that.</li>
    <li><b>The trust deed or indenture.</b> The governing instrument for the Robinson-Huron settlement trust held at BMO Trust Company, including the trustee(s), the schedule of permitted investments, the conflict-of-interest provisions binding the trustees and any release authorities, and the compensation arrangements for the trustee(s) and any advisor acting in connection with the trust. The Nation's published BMO quarterly report (quarter ending December 31, 2025) shows the trust held about $219 million invested in the BMO AM Balanced Fund, so the holdings are visible; what is not is the governing instrument. In particular I am asking for the trust indenture, the process and authorities for approving a withdrawal, the terms of the separate trust for members under 18, and any trustee, advisor, or management fees. The September 2025 engagement materials describe a proposed Trust Committee that would recommend the annual cash-flow allocation to Chief and Council for approval, and a distribution policy that was still being finalized. I am asking for the final adopted trust income-distribution policy, the Trust Committee's terms of reference and current membership, and confirmation of the corporate trustee (and any individual co-trustee or protector).</li>
    <li><b>The financial-advisor engagement.</b> The engagement terms for the external Financial Advisor named throughout Council minutes (McLeod Consulting): the scope of work, the fee or compensation basis, the term, and whether the engagement was sole-sourced or competitively procured.</li>
  </ol>

  <h3>Governance and conflict of interest</h3>
  <ol class="rrl-list" start="10">
    <li><b>The Freed financing vote.</b> The portion of the minutes recording the reasons given for the four abstentions, together with the written disclosures required of a councillor under Financial Administration Law section 22(3), the conflict-of-interest policy Council is required to maintain under section 21, and the annual written conflict-of-interest disclosures each councillor must file with the chief administrative officer under section 22(2).</li>
    <li><b>The organizational meeting of August 26, 2024.</b> The minutes of the Chief and Council organizational meeting at which board and committee appointments were set. This meeting does not appear in the materials otherwise available to members.</li>
    <li><b>The current organizational chart.</b> The most recent Council-approved organizational chart, which under the Nation's Personnel Policy and Procedure Manual (section A-1.5) and the Financial Administration Law (section 20) is to be prepared by the chief administrative officer, approved by Council, and kept current, and which under Financial Administration Law section 20(3) the chief administrative officer must provide to a member of the First Nation on request. Please include the date Council last approved it.</li>
    <li><b>The Finance and Audit Committee.</b> The Committee's current membership and Chair; the independence criteria and the most recent signed annual independence statements required under Financial Administration Law section 11(4); and the Committee's reports to Council, including the annual report on the effectiveness of the whistleblowing and Code of Conduct policies. The Financial Administration Law requires the Committee's members to be independent; given the overlap shown in the table above, the Committee's composition and its independence statements are especially relevant.</li>
    <li><b>Committees and working groups.</b> The current membership and terms of reference of all Council committees and working groups. The Nation's most recent posted list (January 2024) sets out nineteen committees and working groups, but only those on the Governance Department's page are described publicly, and committee members are appointed by Band Council Resolution (including BCR 2024-05-70) that is not posted. I would appreciate the membership and terms of reference of each, and the committee-appointment resolutions.</li>
  </ol>

  <h3>Member data and privacy</h3>
  <ol class="rrl-list" start="15">
    <li><b>Privacy and data governance.</b> Confirmation of whether the employee required under section B-3.3 of the Personnel Policy and Procedure Manual (in place since 2021) to manage privacy compliance was ever designated, and who currently performs that function; the terms of reference and reporting line for the new Privacy Officer position; the Nation's data-breach notification policy; and the Internal Disclosure (Whistleblowing) policy at section C-3.18, including confirmation that the confidential reporting procedure the chief administrative officer is required to establish is in place, and its current working contact points.</li>
  </ol>

  <h3>Process</h3>
  <ol class="rrl-list" start="16">
    <li><b>The records-access process itself.</b> The Nation's formal process for a member to request records of this kind, including the appropriate office or Privacy Officer to direct such requests to, the expected timelines, and any applicable fees.</li>
  </ol>

  <h3>Basis for this request</h3>
  <p>This request draws on the Nation's own records and on public sources, so that each item can be verified rather than taken on faith:</p>
  <ul class="rrl-basis">
    <li>The <b>FY2025 audited consolidated financial statements</b> (including Note 14, loans to Government Business Enterprises; the consolidated-entities note; and the Robinson-Huron settlement reserve).</li>
    <li>The <b>FNFTA Schedule of Remuneration and Expenses</b> of Chief and Council, published annually under the First Nations Financial Transparency Act.</li>
    <li>The <b>Sagamok Anishnawbek Financial Administration Law, 2020</b>, including sections 11 and 12 (Finance and Audit Committee), 20 (organizational chart), 21 and 22 (conflict of interest), 36, 40 and 41 (borrowing, for-profit activity, and guarantees), and 72 and 73 (reporting breaches).</li>
    <li>The <b>Personnel Policy and Procedure Manual, 2020</b>, including sections A-1.5 (organizational chart), B-3.3 (privacy), and C-3.18 (internal disclosure / whistleblowing).</li>
    <li>The <b>Governance Department page</b> on the Nation's website (the accountability and transparency mandate quoted above).</li>
    <li>The <b>Ontario Business Registry</b>, including the corporate profiles for 2262012 Ontario Limited (GR Truss) and 2344827 Ontario Inc. (Ritchie Falls).</li>
    <li><b>Corporations Canada</b> profiles for Sagamok Development Corporation and 15558409 Canada Ltd.</li>
    <li>The <b>Council motions and Band Council Resolutions</b> referenced above, including Motion 2024/10 #07 and Band Council Resolutions 2024-05-69, 2024-05-70, 2025-05-59, 2025-12-80, and 2023-11-40.</li>
  </ul>

  <p style="margin-top: var(--gap-5)">I have directed this request to Chief and Council through the Council Secretariat rather than to a single department. If any item is more appropriately handled elsewhere, please let me know and I will follow the process you advise. I am happy to receive these records electronically or to arrange supervised in-person viewing where that is the Nation's practice for sensitive documents, and I am glad to meet to discuss the request.</p>

  <p>So that this does not sit unanswered, I would appreciate a response within 30 days, together with the Nation's own records-access timelines if they differ. If it is easier to respond in stages, I would welcome the first group, "Benefit to members, and the investments behind it," first.</p>

  <p>Miigwech for your time and your attention to this. I look forward to your response.</p>

  <div class="rrl-sig">
    <p>Respectfully,</p>
    <p style="margin-top: var(--gap-4)">A member of Sagamok Anishnawbek</p>
  </div>

  <div class="rrl-cta">
    <h3>Add your voice</h3>
    <p>If you are a member or a supporter, you can <a href="/get-involved">get involved with the Circle &rarr;</a></p>
  </div>

  <h3>Amendments and revision history</h3>
  <p>This request was submitted to Chief and Council on June 10, 2026. This online version is kept current, and any change to it is logged here, with the date and reason, so members can see exactly what has changed.</p>
  <ul class="rrl-basis">
    <li><b>June 10, 2026</b> &middot; Submitted to Chief and Council via the Council Secretariat, by mail and email, with 28 member and 2 supporter signatures and a 30-day response requested.</li>
    <li><b>June 10, 2026</b> &middot; This online version carries two items beyond the paper copy circulated for signature: "The off-reserve real-estate structure" and "Committees and working groups." Item 8 (the trust) and the board table's source note were also expanded with additional sourced detail. No item was removed or narrowed.</li>
    <li><b>June 15, 2026</b> &middot; Items 10 and 12 also ask who currently performs the chief administrative officer function, as the Nation is advertising a Senior Administration Officer position and the office the Financial Administration Law routes the organizational chart (s.20(3)) and councillors' conflict-of-interest disclosures (s.22(2)) through appears to be vacant.</li>
  </ul>
</article>
{% endblock %}

{% block scripts %}
<script>
  (function () {
    var card = document.querySelector('[data-rr]');
    if (!card) return;
    var SLUG = 'records-request-support';
    var form = card.querySelector('[data-rr-form]');
    var msg = card.querySelector('[data-rr-msg]');
    var submit = card.querySelector('[data-rr-submit]');

    function fmt(n) { try { return Number(n).toLocaleString(); } catch (e) { return String(n); } }

    function setCount(n) {
      if (n === null || n === undefined) return;
      var box = card.querySelector('[data-rr-countbox]');
      var el = card.querySelector('[data-rr-count]');
      if (el) el.textContent = fmt(n);
      if (box) box.hidden = false;
    }

    function setPaper(count, note) {
      if (!count || !note) return;
      var el = card.querySelector('[data-rr-paper]');
      if (el) { el.textContent = note; el.hidden = false; }
    }

    function renderSupporters(recent) {
      if (!recent || !recent.length) return;
      var wrap = document.querySelector('[data-rr-supporters]');
      var list = document.querySelector('[data-rr-supporters-list]');
      if (!wrap || !list) return;
      list.innerHTML = '';
      recent.forEach(function (s) {
        var li = document.createElement('li');
        li.textContent = s.name;
        list.appendChild(li);
      });
      wrap.hidden = false;
    }

    function hydrate() {
      fetch('/api/petition/' + SLUG, { headers: { 'Accept': 'application/json' } })
        .then(function (r) { return r.ok ? r.json() : null; })
        .then(function (d) { if (d && d.ok) { setCount(d.count); setPaper(d.paper_count, d.paper_note); renderSupporters(d.recent); } })
        .catch(function () {});
    }

    function checked(name) {
      var el = form.querySelector('input[name="' + name + '"]:checked');
      return el ? el.value : '';
    }

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      if (msg) { msg.textContent = ''; msg.classList.remove('is-error'); }

      var payload = {
        campaign: SLUG,
        name: (form.elements['name'] || {}).value || '',
        email: (form.elements['email'] || {}).value || '',
        member_flag: checked('member_flag') || 'supporter',
        comment: (form.elements['comment'] || {}).value || '',
        include_name_on_letter: checked('include_name_on_letter') === 'yes',
        show_name_publicly: checked('show_name_publicly') === 'yes',
        consent: true,
        website: (form.elements['website'] || {}).value || ''
      };

      if (!payload.name.trim()) {
        if (msg) { msg.textContent = 'Please enter your name.'; msg.classList.add('is-error'); }
        return;
      }
      if (submit) { submit.disabled = true; submit.textContent = 'Adding...'; }

      fetch('/api/petition/sign', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify(payload)
      })
        .then(function (r) { return r.json().then(function (b) { return b; }); })
        .then(function (res) {
          if (!res || !res.ok) {
            if (msg) { msg.textContent = (res && res.error) || 'Something went wrong. Please try again.'; msg.classList.add('is-error'); }
            if (submit) { submit.disabled = false; submit.textContent = 'Add my name'; }
            return;
          }
          card.classList.add('is-done');
          setCount(res.count);
          var dc = card.querySelector('[data-rr-donecount]');
          if (dc && res.count != null) dc.textContent = 'You are one of ' + fmt(res.count) + ' so far.';
          var rw = card.querySelector('[data-rr-removewrap]');
          var rl = card.querySelector('[data-rr-remove]');
          if (rw && rl && res.manage_url) { rl.setAttribute('href', res.manage_url); rw.hidden = false; }
        })
        .catch(function () {
          if (msg) { msg.textContent = 'Could not reach the server. Please try again.'; msg.classList.add('is-error'); }
          if (submit) { submit.disabled = false; submit.textContent = 'Add my name'; }
        });
    });

    var shareUrl = location.origin + '/standard/records-request';

    function copyLink(btn) {
      var orig = btn.getAttribute('data-orig') || btn.textContent;
      btn.setAttribute('data-orig', orig);
      var ok = function () { btn.textContent = 'Link copied'; setTimeout(function () { btn.textContent = orig; }, 2000); };
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(shareUrl).then(ok).catch(function () { window.prompt('Copy this link:', shareUrl); });
      } else {
        window.prompt('Copy this link:', shareUrl);
      }
    }

    function nativeShare() {
      if (!navigator.share) return;
      navigator.share({
        title: 'Support the member records request',
        text: 'Add your name to the member records request to Sagamok Chief and Council.',
        url: shareUrl
      }).catch(function () {});
    }

    card.querySelectorAll('[data-rr-copy]').forEach(function (btn) {
      btn.addEventListener('click', function () { copyLink(btn); });
    });

    if (navigator.share) {
      card.querySelectorAll('[data-rr-share]').forEach(function (btn) {
        btn.hidden = false;
        btn.addEventListener('click', nativeShare);
      });
    }

    hydrate();
  })();
</script>
{% endblock %}
