{% extends 'base.html.twig' %}
{% set nav = 'resources' %}

{#
  RESOURCES / SCOPE: this directory is RHT-scoped and renders from the Anokii
  graph (front-door services only), so it stays in sync with the Ask box and
  inherits Place coordinates. Data hygiene from research/resources-directory.md
  is carried in the graph: the Sault friendship centre links to ssmifc.ca only;
  NAN Hope / Nishnawbe-Aski Legal Services / AETS are not presented as RHT;
  Anishinabek Nation and Chiefs of Ontario are Ontario-wide, noted below. Phone
  numbers come from each service's curated chunk; websites are its source_url.
#}

{% block title %}Resources: get help · Robinson Huron Treaty{% endblock %}
{% block description %}A member-facing directory of front doors across the territory: Indigenous health authorities, tribal councils and the treaty body, crisis lines, policing, mental health and addictions, legal and family supports, education and training, and housing. Filter by area, or show the nearest.{% endblock %}
{% block og_description %}Get help: a directory of Indigenous health, tribal councils, crisis lines, policing, legal and family, education, and housing front doors across the Robinson Huron Treaty territory.{% endblock %}

{% block main_class %}wrap wrap--wide{% endblock %}

{% block head_styles %}
  <style>
    .rintro { max-width: 70ch; }
    /* Sticky filter bar. */
    .rfilter { position: sticky; top: 0; z-index: 20; display: flex; flex-wrap: wrap; align-items: flex-end; gap: 14px;
      background: var(--paper); border-bottom: 1px solid var(--rule); padding: 12px 0; margin: 0 0 var(--gap-5, 20px); }
    .rfilter__group { display: flex; flex-direction: column; gap: 4px; }
    .rfilter__label { font-family: var(--sans); font-size: 12px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-2); }
    .rfilter__select { font: inherit; color: var(--ink); background: #fff; border: 1px solid var(--rule-strong, #d6cdea); border-radius: 8px; padding: 8px 10px; min-width: 200px; }
    .rfilter__near { font: inherit; font-weight: 600; color: #fff; background: var(--indigo); border: 0; border-radius: 999px; padding: 9px 18px; cursor: pointer; align-self: flex-end; }
    .rfilter__near:hover { background: var(--indigo-deep); }
    .rfilter__select:focus-visible, .rfilter__near:focus-visible { outline: 3px solid var(--magenta); outline-offset: 2px; }
    .rfilter__note { flex: 1 1 100%; margin: 0; font-size: 12.5px; line-height: 1.5; color: var(--ink-3); }
    .rfilter__status { flex: 1 1 100%; margin: 0; font-size: 13px; color: var(--ink-2); min-height: 1em; }

    .rsection { margin: 0 0 var(--gap-6, 32px); }
    .rsection__head h2 { margin: 0 0 4px; }
    .rsection[hidden] { display: none; }

    /* Responsive card grid: 1 / 2 / 3 columns. */
    .rgrid { display: grid; grid-template-columns: 1fr; gap: 16px; }
    @media (min-width: 560px) { .rgrid { grid-template-columns: repeat(2, 1fr); } }
    @media (min-width: 920px) { .rgrid { grid-template-columns: repeat(3, 1fr); } }

    .rcard { display: flex; flex-direction: column; gap: 8px; background: var(--paper-2); border: 1px solid var(--rule); border-radius: 12px; padding: 16px 18px; }
    .rcard[hidden] { display: none; }
    .rcard__top { display: flex; align-items: flex-start; justify-content: space-between; gap: 10px; }
    .rcard__name { font-family: var(--serif); font-size: 18px; font-weight: 600; line-height: 1.2; color: var(--ink); margin: 0; }
    .rcard__blurb { font-size: 14px; line-height: 1.5; color: var(--ink-2); margin: 0; }
    .rcard__links { display: flex; flex-wrap: wrap; gap: 8px 16px; margin: auto 0 0; padding-top: 6px; font-size: 14px; }
    .rcard__tel { font-weight: 600; color: var(--indigo); }
    .rcard__site { color: var(--magenta-deep, #98146d); }
    .rc-chip { flex: none; font-size: 11px; font-weight: 600; letter-spacing: 0.03em; color: var(--indigo); background: var(--paper-3, #ece7f7); border-radius: 999px; padding: 3px 9px; white-space: nowrap; }

    .rnote { max-width: 70ch; }

    /* Featured call-to-action callout (above the grid). */
    .cta { display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 14px 24px;
      background: var(--paper-2); border: 1px solid var(--rule); border-left: 5px solid var(--magenta);
      border-radius: 14px; padding: 20px 24px; margin: 0 0 var(--gap-5, 20px); }
    .cta__body { flex: 1 1 320px; }
    .cta__h { font-family: var(--serif); font-size: clamp(20px, 3vw, 26px); font-weight: 600; line-height: 1.15; color: var(--indigo-deep); margin: 0 0 6px; }
    .cta__line { font-size: 15px; line-height: 1.5; color: var(--ink-2); margin: 0; max-width: 70ch; }
    .cta__btn { flex: none; font-family: var(--sans); font-size: 15px; font-weight: 700; color: #fff; background: var(--indigo);
      border-radius: 999px; padding: 12px 24px; text-decoration: none; white-space: nowrap; }
    .cta__btn:hover { background: var(--indigo-deep); }
    .cta__btn:focus-visible { outline: 3px solid var(--magenta); outline-offset: 2px; }
    .rsection__note { max-width: 70ch; margin: 12px 0 0; }
  </style>
{% endblock %}

{% block hero %}
<section class="hero">
  <div class="wrap wrap--wide">
    <p class="eyebrow">Resources</p>
    <h1>Get help.</h1>
    <p class="lead rintro">Front doors across the territory: who to call and where to start. Each card links to the service's own site as the authority. If you need help right now, the crisis lines are at the top. Filter by your area, or show the nearest.</p>
  </div>
</section>
{% endblock %}

{% block content %}
  {% include 'components/crisis_banner.html.twig' %}

  {% include 'components/cta_callout.html.twig' with {
    id: 'paying-for-school',
    heading: 'Paying for school',
    line: 'Funding for college, university, and the trades: band funding, OSAP, Indspire, ISET training, apprenticeship supports, and the federal bursary search. Most can be combined.',
    button_label: 'See the funding paths',
    href: '/resources/paying-for-school',
  } only %}

  {% include 'components/region_filter.html.twig' with { regions: regions, categories: categories } only %}

  {% for g in groups %}
    <section class="rsection" data-topic="{{ g.topic != '' ? g.topic : 'friendship-centres' }}">
      {% include 'components/section_heading.html.twig' with { title: g.label } only %}
      {% include 'components/resource_grid.html.twig' with { cards: g.cards } only %}
      {% if g.topic == 'education-youth' %}
        <p class="muted rsection__note">For the full list of ways to pay for college, university, and the trades, see <a href="/resources/paying-for-school">Paying for school</a>.</p>
      {% endif %}
    </section>
  {% endfor %}

  <div class="card card--coral rnote">
    <p class="muted">Where the Anishinabek Police Service or UCCM Anishnaabe Police do not serve, the OPP non-emergency line is 1-888-310-1122. For an emergency, always call 911. The Anishinabek Nation and the Chiefs of Ontario are Ontario-wide bodies, not Robinson Huron Treaty organizations.</p>
    <p class="muted">A community resource. We link to each service's own site as the authority, and details are point-in-time. If something is wrong or out of date, tell us through the <a href="/contact">contact form</a>.</p>
    {% include 'components/freshness.html.twig' with { datetime: last_updated('resources') } only %}
  </div>

  <script>
    (function () {
      var root = document;
      var regionSel = root.querySelector('[data-rf-region]');
      var catSel = root.querySelector('[data-rf-cat]');
      var nearBtn = root.querySelector('[data-rf-near]');
      var status = root.querySelector('[data-rf-status]');
      var sections = Array.prototype.slice.call(root.querySelectorAll('.rsection'));
      if (!sections.length) return;

      function applyFilters() {
        var region = regionSel ? regionSel.value : '';
        var cat = catSel ? catSel.value : '';
        sections.forEach(function (sec) {
          var catMatch = !cat || sec.getAttribute('data-topic') === cat;
          var anyVisible = false;
          sec.querySelectorAll('.rcard').forEach(function (card) {
            var show = catMatch && (!region || card.getAttribute('data-region') === region);
            card.hidden = !show;
            if (show) anyVisible = true;
          });
          sec.hidden = !anyVisible;
        });
      }

      if (regionSel) regionSel.addEventListener('change', applyFilters);
      if (catSel) catSel.addEventListener('change', applyFilters);

      function haversine(la1, lo1, la2, lo2) {
        function r(d) { return d * Math.PI / 180; }
        var dLa = r(la2 - la1), dLo = r(lo2 - lo1);
        var a = Math.sin(dLa / 2) * Math.sin(dLa / 2) +
          Math.cos(r(la1)) * Math.cos(r(la2)) * Math.sin(dLo / 2) * Math.sin(dLo / 2);
        return 6371 * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
      }

      if (nearBtn && navigator.geolocation) {
        nearBtn.addEventListener('click', function () {
          status.textContent = 'Asking your device for your location...';
          navigator.geolocation.getCurrentPosition(function (pos) {
            var myLat = pos.coords.latitude, myLng = pos.coords.longitude;
            sections.forEach(function (sec) {
              var grid = sec.querySelector('[data-rgrid]');
              if (!grid) return;
              var cards = Array.prototype.slice.call(grid.querySelectorAll('.rcard'));
              cards.forEach(function (c) {
                var la = parseFloat(c.getAttribute('data-lat')), lo = parseFloat(c.getAttribute('data-lng'));
                c._dist = (isFinite(la) && isFinite(lo) && (la || lo)) ? haversine(myLat, myLng, la, lo) : Infinity;
              });
              cards.sort(function (a, b) { return a._dist - b._dist; });
              cards.forEach(function (c) { grid.appendChild(c); });
            });
            status.textContent = 'Sorted by distance from you. Nothing was stored or sent.';
          }, function () {
            status.textContent = 'Could not get your location. You can still filter by area above.';
          }, { enableHighAccuracy: false, timeout: 10000, maximumAge: 0 });
        });
      } else if (nearBtn) {
        nearBtn.hidden = true;
      }
    })();
  </script>
{% endblock %}
