{# The standard profile facts, as an at-a-glance grid. Expects `nation`.
   Population keeps its point-in-time source and caveat in the note. #}
{% set facts = [
  { label: 'Anishinaabemowin', value: nation.anishinaabemowin },
  { label: 'Sub-region', value: nation.sub_region },
  { label: 'Location', value: nation.nearest_town },
  {
    label: 'Population',
    value: nation.population_total ~ (nation.population_on_reserve ? ', ' ~ nation.population_on_reserve ~ ' on-reserve' : ''),
    note: 'Source: ' ~ nation.population_source ~ '. This is a point-in-time figure; registered membership, on-reserve census counts, and band totals are not directly comparable. Re-verify before relying on it.'
  },
  { label: 'Governance', value: nation.governance },
  { label: 'Primary language', value: nation.language },
  { label: 'Tribal council', value: nation.tribal_council },
] %}
{% include 'components/key_facts.html.twig' with { facts: facts } only %}
